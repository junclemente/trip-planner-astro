  const v = value ? esc(value) : `<span class="text-gray-400 italic text-xs">${placeholder}</span>`;
  return `<div class="flex justify-between items-baseline gap-3 py-1.5 border-b border-gray-50 last:border-0">
    <span class="text-gray-500 text-sm flex-shrink-0">${label}</span>
    <span class="font-medium text-sm text-right break-all">${v}</span>
  </div>`;
}

function renderInfo() {
  const panel = document.getElementById('tab-info');
  panel.innerHTML =
    renderInfoBasics() +
    renderInfoFlight() +
    renderInfoHotel() +
