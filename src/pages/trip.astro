  });
}

function autoAdjustDestinationDates(trip) {
  if (!trip.destinations || trip.destinations.length <= 1) {
    // Single destination: arrival = trip start, departure = trip end
    if (trip.destinations && trip.destinations.length === 1) {
      trip.destinations[0].arrivalDate = trip.startDate;
      trip.destinations[0].departureDate = trip.endDate;
    }
    return trip;
  }

  // Sort destinations by arrival date
  trip.destinations.sort((a, b) =>
    new Date(a.arrivalDate || '1970-01-01') - new Date(b.arrivalDate || '1970-01-01')
  );

  // Chain dates: each destination's departure = next destination's arrival
  for (let i = 0; i < trip.destinations.length - 1; i++) {
    trip.destinations[i].departureDate = trip.destinations[i + 1].arrivalDate;
  }

  // First destination arrival always = trip start date
  trip.destinations[0].arrivalDate = trip.startDate;

  // Last destination departure always = trip end date
  trip.destinations[trip.destinations.length - 1].departureDate = trip.endDate;

  return trip;
}

function recalcDatesFromDests() {
  const dests = trip.destinations ?? [];
  if (dests.length === 0) return false;

  // Apply auto-adjustment logic
  autoAdjustDestinationDates(trip);

  const arrivals = dests.map(d => d.arrivalDate).filter(Boolean).sort();
  const departures = dests.map(d => d.departureDate).filter(Boolean).sort();
  if (!arrivals.length || !departures.length) return false;
  const newStart = arrivals[0];
  const newEnd = departures[departures.length - 1];
  const nights = Math.round((new Date(newEnd + 'T12:00:00') - new Date(newStart + 'T12:00:00')) / 86400000);
  if (nights < 0) return false;
  const oldDays = trip.days ?? [];
  const newDays = buildDays(tripId, newStart, nights);
  const newDateMap = {};
  newDays.forEach(d => { newDateMap[d.date] = d.id; });
  (trip.itineraryEvents ?? []).forEach(ev => {
    const old = oldDays.find(d => d.id === ev.dayId);
    if (old) ev.dayId = newDateMap[old.date] ?? newDays[newDays.length - 1]?.id ?? ev.dayId;
  });
  trip.startDate = newStart; trip.endDate = newEnd; trip.nights = nights; trip.days = newDays;
  return true;
}

function saveInfoSection(section) {
  let suggestSection = null;
  if (section === 'basics') {
    const originCity = document.getElementById('info-origin').value.trim() || null;
    if (!trip.origin) trip.origin = {};
    trip.origin.city = originCity ?? '';
    trip.departFrom = originCity;
    trip.name = document.getElementById('info-name').value.trim() || trip.name;
    trip.notes = document.getElementById('info-notes').value.trim() || null;
    const hasDests = (trip.destinations ?? []).length > 0;
    if (!hasDests) {
      const start = document.getElementById('info-start')?.value;
      const end = document.getElementById('info-end')?.value;
      if (start && end) {
        const nights = Math.round((new Date(end + 'T12:00:00') - new Date(start + 'T12:00:00')) / 86400000);
        const datesChanged = start !== trip.startDate || end !== trip.endDate;
        if (datesChanged && nights >= 0) {
          const oldDays = trip.days ?? [];
          const newDays = buildDays(tripId, start, nights);
          const newDateMap = {};
          newDays.forEach(d => { newDateMap[d.date] = d.id; });
          (trip.itineraryEvents ?? []).forEach(ev => {
            const old = oldDays.find(d => d.id === ev.dayId);
            if (old) ev.dayId = newDateMap[old.date] ?? newDays[newDays.length - 1]?.id ?? ev.dayId;
          });
          trip.startDate = start; trip.endDate = end;
          trip.nights = nights >= 0 ? nights : trip.nights;
          trip.days = newDays;
        }
      }
    }
  } else if (section === 'documents') {
    if (!trip.travelDocuments) trip.travelDocuments = { passport: {}, insurance: {}, customReminders: [], dismissedVisaReminders: [] };
    trip.travelDocuments.passport = {
      name: document.getElementById('doc-passport-name')?.value.trim() ?? '',
      expiryDate: document.getElementById('doc-passport-expiry')?.value ?? '',
    };
    const hasIns = document.getElementById('doc-insurance-check')?.checked ?? false;
    trip.travelDocuments.insurance = {
      hasInsurance: hasIns,
      provider: document.getElementById('doc-ins-provider')?.value.trim() ?? '',
      policyNumber: document.getElementById('doc-ins-policy')?.value.trim() ?? '',
      notes: document.getElementById('doc-ins-notes')?.value.trim() ?? '',
    };
  } else if (section === 'flight') {
    const prevFO = JSON.stringify(trip.flightOut ?? {}), prevFR = JSON.stringify(trip.flightReturn ?? {});
    trip.flightOut = { airline: document.getElementById('fo-airline').value.trim() || null, flightNumber: document.getElementById('fo-number').value.trim() || null, departTime: document.getElementById('fo-depart').value || null, arriveTime: document.getElementById('fo-arrive').value || null, confirmation: document.getElementById('fo-confirm').value.trim() || null };
    trip.flightReturn = { airline: document.getElementById('fr-airline').value.trim() || null, flightNumber: document.getElementById('fr-number').value.trim() || null, departTime: document.getElementById('fr-depart').value || null, arriveTime: document.getElementById('fr-arrive').value || null, confirmation: document.getElementById('fr-confirm').value.trim() || null };
    if ((trip.flightOut.airline || trip.flightOut.flightNumber || trip.flightReturn.airline || trip.flightReturn.flightNumber) &&
        (JSON.stringify(trip.flightOut) !== prevFO || JSON.stringify(trip.flightReturn) !== prevFR)) suggestSection = 'flight';
  } else if (section === 'hotel') {
    const prev = JSON.stringify(trip.hotel ?? {});
    trip.hotel = { name: document.getElementById('h-name').value.trim() || null, address: document.getElementById('h-address').value.trim() || null, checkInDate: document.getElementById('h-checkin-date').value || null, checkInTime: document.getElementById('h-checkin-time').value || null, checkOutDate: document.getElementById('h-checkout-date').value || null, checkOutTime: document.getElementById('h-checkout-time').value || null, confirmation: document.getElementById('h-confirm').value.trim() || null, notes: document.getElementById('h-notes').value.trim() || null };
    if (trip.hotel.name && JSON.stringify(trip.hotel) !== prev) suggestSection = 'hotel';
  } else if (section === 'transport') {
    trip.transport = { gettingThere: document.getElementById('t-there').value.trim() || null, gettingThereNotes: document.getElementById('t-there-notes').value.trim() || null, gettingBack: document.getElementById('t-back').value.trim() || null, gettingBackNotes: document.getElementById('t-back-notes').value.trim() || null };
  }
  saveTrip(trip); editingSection = null; renderHeader(); renderItinerary(); renderInfo();
  window.showToast?.('Saved');
  if (suggestSection) setTimeout(() => offerItineraryEvents(suggestSection), 400);
}

// ── Itinerary Event Suggestions ───────────────────────────────────────────────

function buildItinerarySuggestions(section) {
  const suggestions = [];
  const firstDay = trip.days?.[0], lastDay = trip.days?.[trip.days.length - 1];
  if (section === 'flight') {
    const fo = trip.flightOut ?? {};
    if (fo.airline || fo.flightNumber) {
      const label = fo.flightNumber ?? fo.airline ?? 'Outbound Flight';
      const route = trip.departFrom && trip.destination ? ` · ${trip.departFrom} → ${trip.destination}` : '';
      suggestions.push({ title: `${label}${route}`, dayId: firstDay?.id ?? null, dayLabel: firstDay?.label ?? 'Day 1', time: fo.departTime ?? null, notes: fo.confirmation ? `Conf: ${fo.confirmation}` : '' });
    }
    const fr = trip.flightReturn ?? {};
    if (fr.airline || fr.flightNumber) {
      const label = fr.flightNumber ?? fr.airline ?? 'Return Flight';
      const route = trip.destination && trip.departFrom ? ` · ${trip.destination} → ${trip.departFrom}` : '';
      suggestions.push({ title: `${label}${route}`, dayId: lastDay?.id ?? null, dayLabel: lastDay?.label ?? 'Last Day', time: fr.departTime ?? null, notes: fr.confirmation ? `Conf: ${fr.confirmation}` : '' });
    }
  }
  if (section === 'hotel') {
    const h = trip.hotel ?? {};
    if (h.name) {
      const ciDay = h.checkInDate ? (trip.days?.find(d => d.date === h.checkInDate) ?? firstDay) : firstDay;
      const coDay = h.checkOutDate ? (trip.days?.find(d => d.date === h.checkOutDate) ?? lastDay) : lastDay;
      suggestions.push({ title: `Hotel Check-in: ${h.name}`, dayId: ciDay?.id ?? null, dayLabel: ciDay?.label ?? '', time: h.checkInTime ?? null, notes: h.confirmation ? `Conf: ${h.confirmation}` : '' });
      suggestions.push({ title: `Hotel Check-out: ${h.name}`, dayId: coDay?.id ?? null, dayLabel: coDay?.label ?? '', time: h.checkOutTime ?? null, notes: '' });
    }
  }
  return suggestions;
}

function offerItineraryEvents(section) {
  const suggestions = buildItinerarySuggestions(section);
  if (!suggestions.length) return;
  document.getElementById('suggest-events-list').innerHTML = suggestions.map((s, i) => `
    <label class="flex items-start gap-2.5 cursor-pointer p-2 rounded-lg hover:bg-gray-50">
      <input type="checkbox" class="suggest-ev-check mt-0.5 text-indigo-600 rounded" data-idx="${i}" checked />
      <div><p class="text-sm font-medium text-gray-800">${esc(s.title)}</p>
        <p class="text-xs text-gray-500">${esc(s.dayLabel)}${s.time ? ' · ' + s.time : ''}</p></div>
    </label>`).join('');
  openModal('modal-suggest-events');
  document.getElementById('suggest-events-skip').onclick = () => closeModal('modal-suggest-events');
  document.getElementById('suggest-events-add').onclick = () => {
    const checks = document.querySelectorAll('.suggest-ev-check:checked');
    if (!trip.itineraryEvents) trip.itineraryEvents = [];
    checks.forEach(cb => {
      const s = suggestions[parseInt(cb.dataset.idx)];
      trip.itineraryEvents.push({ id: genId(), tripId, dayId: s.dayId, time: s.time, title: s.title, notes: s.notes ?? '' });
    });
    saveTrip(trip); closeModal('modal-suggest-events'); renderItinerary();
    if (checks.length > 0) window.showToast?.(`${checks.length} event${checks.length > 1 ? 's' : ''} added to itinerary`);
  };
}

// ── Trip Members ──────────────────────────────────────────────────────────────

function getMembers() { return trip.members ?? []; }
function getMemberName(id) { return getMembers().find(m => m.id === id)?.name ?? `Unknown (${id.slice(-4)})`; }

function openMemberModal() {
  const members = getMembers();
  const global = (profile.globalPeople ?? []).filter(p => !members.some(m => m.name.toLowerCase() === p.name.toLowerCase()));
  const importList = document.getElementById('member-import-list');
  const importEmpty = document.getElementById('member-import-empty');
  document.getElementById('member-new-name').value = '';
  document.getElementById('member-save-global').checked = false;

  if (global.length > 0) {
    importList.innerHTML = global.map(p => `
      <button class="import-global-person text-sm px-3 py-1.5 rounded-full border border-indigo-200 bg-indigo-50 text-indigo-700 hover:bg-indigo-100 flex items-center gap-1.5"
              data-name="${esc(p.name)}">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        ${esc(p.name)}
      </button>`).join('');
    importEmpty.classList.add('hidden');
    importList.querySelectorAll('.import-global-person').forEach(btn => {
      btn.addEventListener('click', () => { addMemberToTrip(btn.dataset.name, false); closeModal('modal-member'); });
    });
  } else {
    importList.innerHTML = '';
    importEmpty.classList.remove('hidden');
  }

  openModal('modal-member');
  setTimeout(() => document.getElementById('member-new-name').focus(), 50);
}

function addMemberToTrip(name, saveToGlobal) {
  if (!trip.members) trip.members = [];
  trip.members.push({ id: genId(), name });
  saveTrip(trip);
  if (saveToGlobal) {
    if (!profile.globalPeople) profile.globalPeople = [];
    if (!profile.globalPeople.some(p => p.name.toLowerCase() === name.toLowerCase())) {
      profile.globalPeople.push({ id: genId(), name });
      saveProfile(profile);
    }
  }
  renderInfo();
  renderExpenses();
  window.showToast?.(`${name} added to trip`);
}

document.getElementById('form-member-new').addEventListener('submit', e => {
  e.preventDefault();
  const name = document.getElementById('member-new-name').value.trim();
  if (!name) return;
  const saveGlobal = document.getElementById('member-save-global').checked;
  addMemberToTrip(name, saveGlobal);
  closeModal('modal-member');
});

// ── Expenses Tab ──────────────────────────────────────────────────────────────

const EXPENSE_CATEGORIES = [
  { id: 'food',          label: 'Food & Drink',    color: 'bg-orange-100 text-orange-800' },
  { id: 'transport',     label: 'Transport',        color: 'bg-blue-100 text-blue-800' },
  { id: 'accommodation', label: 'Accommodation',    color: 'bg-yellow-100 text-yellow-800' },
  { id: 'entertainment', label: 'Entertainment',    color: 'bg-purple-100 text-purple-800' },
  { id: 'shopping',      label: 'Shopping',         color: 'bg-pink-100 text-pink-800' },
  { id: 'other',         label: 'Other',            color: 'bg-gray-100 text-gray-600' },
];

function getExpenses() { return trip.expenses ?? []; }
function getExpCat(id) { return EXPENSE_CATEGORIES.find(c => c.id === id) ?? EXPENSE_CATEGORIES[EXPENSE_CATEGORIES.length - 1]; }

function renderExpenses() {
  const panel = document.getElementById('tab-expenses');
  const members = getMembers();
  const expenses = getExpenses();

  if (members.length === 0) {
    panel.innerHTML = `
      <div class="px-4 py-14 text-center">
        <p class="text-base font-semibold text-gray-700 mb-2">Add trip members first</p>
        <p class="text-sm text-gray-500 mb-4">Go to Info to add people to split expenses with.</p>
        <button id="exp-go-info" class="btn-primary text-sm">Go to Info Tab</button>
      </div>`;
    panel.querySelector('#exp-go-info')?.addEventListener('click', () => document.querySelector('.tab-btn[data-tab="info"]')?.click());
    return;
  }

  const totalAmount = expenses.reduce((s, e) => s + (e.amount || 0), 0);
  const visible = expenses
    .filter(e => expCategoryFilter === null || (e.category ?? 'other') === expCategoryFilter)
    .filter(e => expPersonFilter === null || e.paidBy === expPersonFilter || (e.splitBetween ?? []).includes(expPersonFilter))
    .sort((a, b) => (b.date ?? '').localeCompare(a.date ?? ''));

  const catTotals = {};
  expenses.forEach(e => { const c = e.category ?? 'other'; catTotals[c] = (catTotals[c] ?? 0) + (e.amount || 0); });

  panel.innerHTML = `
    <div class="sticky top-[97px] bg-white border-b border-gray-100 z-20 px-4 py-3">
      <div class="flex items-center justify-between mb-2">
        <div>
          <span class="text-xl font-bold text-gray-900">${fmt(totalAmount)}</span>
          <span class="text-xs text-gray-500 ml-1.5">${expenses.length} expense${expenses.length !== 1 ? 's' : ''}</span>
        </div>
        <div class="flex gap-2">
          ${expenses.length > 0 ? `<button id="btn-settle-up" class="btn-secondary text-xs py-1.5 px-3">Settle Up</button>` : ''}
          ${!readonly ? `<button id="btn-add-expense" class="btn-primary text-xs py-1.5 px-3">+ Add</button>` : ''}
        </div>
      </div>
      ${expenses.length > 0 ? buildExpFilterBar(expenses, members) : ''}
    </div>

    <div class="divide-y divide-gray-50">
      ${visible.length > 0 ? visible.map(e => renderExpenseRow(e)).join('') : `
        <div class="px-4 py-12 text-center text-sm text-gray-400 italic">
          ${expenses.length > 0 ? 'No expenses match the active filter.' : 'No expenses yet — tap + Add to get started.'}
        </div>`}
    </div>

    ${Object.keys(catTotals).length > 1 ? `
    <div class="px-4 py-4 border-t border-gray-100">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">By Category</p>
      <div class="space-y-1.5">
        ${Object.entries(catTotals).map(([cat, total]) => {
          const c = getExpCat(cat);
          return `<div class="flex justify-between items-center text-sm">
            <span class="badge ${c.color}">${esc(c.label)}</span>
            <span class="font-medium text-gray-800">${fmt(total)}</span>
          </div>`;
        }).join('')}
      </div>
    </div>` : ''}`;

  panel.querySelector('#btn-add-expense')?.addEventListener('click', () => openExpenseModal());
  panel.querySelector('#btn-settle-up')?.addEventListener('click', openSettleUp);
  panel.querySelectorAll('[data-edit-expense]').forEach(btn => btn.addEventListener('click', () => openExpenseModal(btn.dataset.editExpense)));
  panel.querySelectorAll('[data-del-expense]').forEach(btn => btn.addEventListener('click', () => deleteExpense(btn.dataset.delExpense)));
  panel.querySelectorAll('.exp-filter-cat').forEach(btn => btn.addEventListener('click', () => { expCategoryFilter = btn.dataset.cat || null; renderExpenses(); }));
  panel.querySelectorAll('.exp-filter-person').forEach(btn => btn.addEventListener('click', () => { expPersonFilter = btn.dataset.person || null; renderExpenses(); }));
}

function buildExpFilterBar(expenses, members) {
  const usedCats = [...new Set(expenses.map(e => e.category ?? 'other'))];
  return `<div class="space-y-1.5">
    ${usedCats.length > 1 ? `<div class="flex gap-1.5 overflow-x-auto pb-0.5" style="scrollbar-width:none">
      <button class="exp-filter-cat text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0 ${expCategoryFilter === null ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600'}" data-cat="">All</button>
      ${usedCats.map(cat => { const c = getExpCat(cat); const cls = expCategoryFilter === cat ? c.color + ' ring-1 ring-inset ring-current' : 'bg-gray-100 text-gray-600'; return `<button class="exp-filter-cat text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0 ${cls}" data-cat="${esc(cat)}">${esc(c.label)}</button>`; }).join('')}
    </div>` : ''}
    ${members.length > 1 ? `<div class="flex gap-1.5 overflow-x-auto pb-0.5" style="scrollbar-width:none">
      <button class="exp-filter-person text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0 ${expPersonFilter === null ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600'}" data-person="">All</button>
      ${members.map(m => { const cls = expPersonFilter === m.id ? 'bg-indigo-100 text-indigo-800 ring-1 ring-inset ring-indigo-300' : 'bg-gray-100 text-gray-600'; return `<button class="exp-filter-person text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0 ${cls}" data-person="${esc(m.id)}">${esc(m.name)}</button>`; }).join('')}
    </div>` : ''}
  </div>`;
}

function renderExpenseRow(expense) {
  const payerName = getMemberName(expense.paidBy);
  const splitNames = (expense.splitBetween ?? []).map(id => getMemberName(id));
  const isCustom = expense.customAmounts && Object.keys(expense.customAmounts).length > 0;
  const shareStr = isCustom ? 'custom' : splitNames.length > 0 ? `${fmt(expense.amount / splitNames.length)}/ea` : '';
  const abbrev = splitNames.length <= 3 ? splitNames.join(', ') : `${splitNames.slice(0, 2).join(', ')} +${splitNames.length - 2}`;
  const cat = getExpCat(expense.category ?? 'other');
  const editDel = !readonly ? `
    <div class="flex gap-0.5 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 ml-1">
      <button data-edit-expense="${esc(expense.id)}" class="btn-ghost p-1.5" title="Edit">✏️</button>
      <button data-del-expense="${esc(expense.id)}" class="btn-ghost p-1.5 text-red-400 hover:text-red-600 text-lg leading-none" title="Delete">×</button>
    </div>` : '';

  return `<div class="group flex gap-3 px-4 py-3 hover:bg-gray-50 transition-colors">
    <div class="flex-1 min-w-0">
      <div class="flex items-center flex-wrap gap-1.5 mb-0.5">
        <span class="text-sm font-semibold text-gray-900">${esc(expense.description)}</span>
        <span class="badge ${cat.color}">${esc(cat.label)}</span>
      </div>
      ${expense.venueOrNote ? `<p class="text-xs text-gray-400 mb-0.5">${esc(expense.venueOrNote)}</p>` : ''}
      <p class="text-xs text-gray-500">
        Paid by <span class="font-medium text-gray-700">${esc(payerName)}</span>
        ${splitNames.length > 0 ? `· <span title="${esc(splitNames.join(', '))}">${esc(abbrev)}</span>` : ''}
        ${expense.date ? `· ${expense.date}` : ''}
      </p>
    </div>
    <div class="text-right flex-shrink-0">
      <p class="text-sm font-bold text-gray-900">${fmt(expense.amount)}</p>
      ${shareStr ? `<p class="text-xs text-gray-400">${shareStr}</p>` : ''}
    </div>
    ${editDel}
  </div>`;
}

function deleteExpense(expenseId) {
  trip.expenses = (trip.expenses ?? []).filter(e => e.id !== expenseId);
  trip.paidSettlements = [];
  saveTrip(trip); renderExpenses(); window.showToast?.('Expense removed');
}

// ── Expense Modal ─────────────────────────────────────────────────────────────

function openExpenseModal(editExpenseId = null) {
  const members = getMembers();
  if (members.length === 0) { window.showToast?.('Add trip members first (Info tab)'); return; }

  document.getElementById('form-expense').reset();
  document.getElementById('expense-edit-id').value = '';
  document.getElementById('modal-expense-title').textContent = editExpenseId ? 'Edit Expense' : 'Add Expense';
  expSplitMethod = 'equal';

  document.getElementById('exp-date').value = trip.startDate ?? '';
  document.getElementById('exp-paid-by').innerHTML =
    members.map(m => `<option value="${esc(m.id)}">${esc(m.name)}</option>`).join('');

  if (editExpenseId) {
    const expense = getExpenses().find(e => e.id === editExpenseId);
    if (expense) {
      document.getElementById('expense-edit-id').value = expense.id;
      document.getElementById('exp-description').value = expense.description ?? '';
      document.getElementById('exp-amount').value = expense.amount ?? '';
      document.getElementById('exp-category').value = expense.category ?? 'food';
      document.getElementById('exp-date').value = expense.date ?? trip.startDate ?? '';
      document.getElementById('exp-venue').value = expense.venueOrNote ?? '';
      document.getElementById('exp-paid-by').value = expense.paidBy ?? '';
      if (expense.customAmounts && Object.keys(expense.customAmounts).length > 0) expSplitMethod = 'custom';
      buildExpSplitCheckboxes(members, expense.splitBetween ?? []);
      if (expSplitMethod === 'custom') setTimeout(() => loadCustomAmounts(expense.customAmounts), 10);
    }
  } else {
    buildExpSplitCheckboxes(members, members.map(m => m.id));
  }

  updateExpSplitMethodUI();
  wireExpenseModalEvents();
  openModal('modal-expense');
  setTimeout(() => document.getElementById('exp-description').focus(), 50);
}

function buildExpSplitCheckboxes(members, selectedIds) {
  document.getElementById('exp-split-list').innerHTML = members.map(m => `
    <label class="flex items-center gap-2 cursor-pointer py-1 select-none">
      <input type="checkbox" class="exp-split-check h-4 w-4 rounded text-indigo-600"
             value="${esc(m.id)}" ${selectedIds.includes(m.id) ? 'checked' : ''} />
      <span class="text-sm text-gray-700 flex-1">${esc(m.name)}</span>
      <span class="exp-person-share text-xs text-gray-400 tabular-nums" data-person="${esc(m.id)}"></span>
    </label>`).join('');
}

function loadCustomAmounts(customAmounts) {
  const list = document.getElementById('exp-custom-list');
  if (!list) return;
  list.querySelectorAll('[data-custom-amount]').forEach(inp => {
    const v = customAmounts?.[inp.dataset.customAmount];
    if (v != null) inp.value = (+v).toFixed(2);
  });
  updateCustomRemaining();
}

function wireExpenseModalEvents() {
  document.querySelectorAll('.exp-split-check').forEach(cb => {
    cb.addEventListener('change', () => { updateExpPerPerson(); if (expSplitMethod === 'custom') rebuildCustomList(); });
  });
  document.getElementById('exp-amount').oninput = () => { updateExpPerPerson(); updateCustomRemaining(); };
  document.getElementById('exp-select-all').onclick = () => {
    const cbs = document.querySelectorAll('.exp-split-check');
    const allChecked = [...cbs].every(cb => cb.checked);
    cbs.forEach(cb => { cb.checked = !allChecked; });
    updateExpPerPerson();
    if (expSplitMethod === 'custom') rebuildCustomList();
  };
  document.getElementById('exp-split-equal').onclick = () => { expSplitMethod = 'equal'; updateExpSplitMethodUI(); };
  document.getElementById('exp-split-custom').onclick = () => { expSplitMethod = 'custom'; updateExpSplitMethodUI(); };
}

function getSelectedSplitIds() {
  return [...document.querySelectorAll('.exp-split-check:checked')].map(cb => cb.value);
}

function updateExpPerPerson() {
  if (expSplitMethod !== 'equal') return;
  const amount = parseFloat(document.getElementById('exp-amount')?.value) || 0;
  const selected = getSelectedSplitIds();
  const perPerson = selected.length > 0 ? amount / selected.length : 0;
  document.querySelectorAll('.exp-person-share').forEach(span => {
    const cb = document.querySelector(`.exp-split-check[value="${CSS.escape(span.dataset.person)}"]`);
    span.textContent = cb?.checked && selected.length > 0 && amount > 0 ? fmt(perPerson) : '';
  });
  const el = document.getElementById('exp-per-person');
  if (el) el.textContent = selected.length > 0 && amount > 0 ? `${fmt(perPerson)} each` : '';
}

function rebuildCustomList() {
  const selected = getSelectedSplitIds();
  const amount = parseFloat(document.getElementById('exp-amount')?.value) || 0;
  const container = document.getElementById('exp-custom-list');
  if (!container) return;
  const existing = {};
  container.querySelectorAll('[data-custom-amount]').forEach(inp => { existing[inp.dataset.customAmount] = inp.value; });
  const defaultShare = selected.length > 0 ? (amount / selected.length).toFixed(2) : '0.00';
  container.innerHTML = selected.map(id => `
    <div class="flex items-center justify-between gap-2">
      <span class="text-sm text-gray-700 flex-1">${esc(getMemberName(id))}</span>
      <div class="flex items-center gap-1">
        <span class="text-xs text-gray-400">$</span>
        <input type="number" min="0" step="0.01" class="input w-24 text-sm py-1 text-right"
               data-custom-amount="${esc(id)}" value="${existing[id] ?? defaultShare}" />
      </div>
    </div>`).join('');
  container.querySelectorAll('[data-custom-amount]').forEach(inp => { inp.addEventListener('input', updateCustomRemaining); });
  updateCustomRemaining();
}

function updateCustomRemaining() {
  if (expSplitMethod !== 'custom') return;
  const amount = parseFloat(document.getElementById('exp-amount')?.value) || 0;
  const allocated = [...document.querySelectorAll('[data-custom-amount]')].reduce((s, i) => s + (parseFloat(i.value) || 0), 0);
  const remaining = amount - allocated;
  const el = document.getElementById('exp-remaining');
  const lbl = document.getElementById('exp-remaining-label');
  if (!el) return;
  el.textContent = fmt(Math.abs(remaining));
  el.className = Math.abs(remaining) < 0.005 ? 'font-semibold text-green-600'
    : remaining < 0 ? 'font-semibold text-red-600' : 'font-semibold text-amber-600';
  if (lbl) lbl.textContent = remaining < -0.005 ? 'over by' : remaining > 0.005 ? 'remaining' : 'balanced ✓';
}

function updateExpSplitMethodUI() {
  const isCustom = expSplitMethod === 'custom';
  const eqBtn = document.getElementById('exp-split-equal');
  const cuBtn = document.getElementById('exp-split-custom');
  if (eqBtn) eqBtn.className = `${isCustom ? 'btn-secondary' : 'btn-primary'} flex-1 text-sm py-1.5`;
  if (cuBtn) cuBtn.className = `${isCustom ? 'btn-primary' : 'btn-secondary'} flex-1 text-sm py-1.5`;
  document.getElementById('exp-custom-amounts')?.classList.toggle('hidden', !isCustom);
  const pp = document.getElementById('exp-per-person');
  if (pp) pp.textContent = '';
  if (isCustom) { rebuildCustomList(); document.querySelectorAll('.exp-person-share').forEach(s => { s.textContent = ''; }); }
  else updateExpPerPerson();
}

document.getElementById('form-expense').addEventListener('submit', e => {
  e.preventDefault();
  const editId = document.getElementById('expense-edit-id').value;
  const description = document.getElementById('exp-description').value.trim();
  const amount = parseFloat(document.getElementById('exp-amount').value);
  const category = document.getElementById('exp-category').value || 'other';
  const date = document.getElementById('exp-date').value || null;
  const venueOrNote = document.getElementById('exp-venue').value.trim() || null;
  const paidBy = document.getElementById('exp-paid-by').value;
  const splitBetween = getSelectedSplitIds();

  if (splitBetween.length === 0) { window.showToast?.('Select at least one person to split with'); return; }
  if (isNaN(amount) || amount <= 0) { window.showToast?.('Enter a valid amount'); return; }

  let customAmounts = null;
  if (expSplitMethod === 'custom') {
    customAmounts = {};
    document.querySelectorAll('[data-custom-amount]').forEach(inp => { customAmounts[inp.dataset.customAmount] = parseFloat(inp.value) || 0; });
    const total = Object.values(customAmounts).reduce((s, v) => s + v, 0);
    if (Math.abs(total - amount) > 0.01) { window.showToast?.('Custom amounts must equal total'); return; }
  }

  const expense = { id: editId || genId(), tripId, description, amount, category, date, venueOrNote, paidBy, splitBetween, customAmounts };
  if (!trip.expenses) trip.expenses = [];
  const idx = trip.expenses.findIndex(ex => ex.id === expense.id);
  if (idx >= 0) trip.expenses[idx] = expense; else trip.expenses.push(expense);
  trip.paidSettlements = [];
  saveTrip(trip); closeModal('modal-expense'); renderExpenses();
  window.showToast?.(editId ? 'Expense updated' : 'Expense added');
});

// ── Settlement ────────────────────────────────────────────────────────────────

function calculateSettlements() {
  const expenses = getExpenses();
  const members = getMembers();
  if (!expenses.length || !members.length) return [];

  const balances = {};
  members.forEach(m => { balances[m.id] = 0; });

  expenses.forEach(expense => {
    if (!(expense.paidBy in balances)) balances[expense.paidBy] = 0;
    balances[expense.paidBy] += expense.amount;
    (expense.splitBetween ?? []).forEach(personId => {
      if (!(personId in balances)) balances[personId] = 0;
      const share = expense.customAmounts?.[personId] != null
        ? expense.customAmounts[personId]
        : expense.amount / (expense.splitBetween?.length || 1);
      balances[personId] -= share;
    });
  });

  const creditors = Object.entries(balances).filter(([, v]) => v > 0.005).map(([id, amount]) => ({ id, amount })).sort((a, b) => b.amount - a.amount);
  const debtors  = Object.entries(balances).filter(([, v]) => v < -0.005).map(([id, amount]) => ({ id, amount: -amount })).sort((a, b) => b.amount - a.amount);

  const transactions = [];
  let ci = 0, di = 0;
  while (ci < creditors.length && di < debtors.length) {
    const credit = creditors[ci], debt = debtors[di];
    const amount = Math.min(credit.amount, debt.amount);
    transactions.push({ from: debt.id, to: credit.id, amount: Math.round(amount * 100) / 100 });
    credit.amount -= amount;
    debt.amount -= amount;
    if (credit.amount < 0.005) ci++;
    if (debt.amount < 0.005) di++;
  }
  return transactions;
}

function openSettleUp() {
  renderSettleContent(calculateSettlements());
  openModal('modal-settle');
}

function renderSettleContent(transactions) {
  const paid = trip.paidSettlements ?? [];
  const paidKeys = new Set(paid.map(p => `${p.from}|${p.to}|${p.amount}`));
  const remaining = transactions.filter(t => !paidKeys.has(`${t.from}|${t.to}|${t.amount}`));
  const container = document.getElementById('settle-content');

  if (transactions.length === 0) {
    container.innerHTML = `<div class="text-center py-8"><p class="text-sm text-gray-500">No expenses to settle.</p></div>`;
    return;
  }

  if (remaining.length === 0) {
    container.innerHTML = `
      <div class="text-center py-8">
        <div class="text-5xl mb-3">🎉</div>
        <h3 class="text-lg font-bold text-gray-800 mb-1">All Settled!</h3>
        <p class="text-sm text-gray-500 mb-4">Everyone's square.</p>
        <button id="settle-reset" class="text-xs text-gray-400 hover:text-gray-600 underline">Reset settlements</button>
      </div>`;
    container.querySelector('#settle-reset').onclick = () => { trip.paidSettlements = []; saveTrip(trip); renderSettleContent(calculateSettlements()); };
    return;
  }

  container.innerHTML = `
    <p class="text-sm text-gray-500 mb-3">Minimum <strong>${transactions.length}</strong> payment${transactions.length !== 1 ? 's' : ''} needed to clear all debts:</p>
    <div class="space-y-2">
      ${transactions.map(t => {
        const isPaid = paidKeys.has(`${t.from}|${t.to}|${t.amount}`);
        return `<div class="flex items-center gap-3 px-3 py-2.5 rounded-lg ${isPaid ? 'bg-green-50' : 'bg-gray-50'}">
          <div class="flex-1 text-sm">
            <span class="font-semibold ${isPaid ? 'text-gray-400 line-through' : 'text-gray-900'}">${esc(getMemberName(t.from))}</span>
            <span class="text-gray-400 mx-1">→</span>
            <span class="font-semibold ${isPaid ? 'text-gray-400 line-through' : 'text-gray-900'}">${esc(getMemberName(t.to))}</span>
            <span class="font-bold ml-1 ${isPaid ? 'text-gray-400 line-through' : 'text-indigo-600'}">${fmt(t.amount)}</span>
          </div>
          ${isPaid
            ? `<span class="text-xs text-green-600 font-medium flex-shrink-0">✓ Paid</span>`
            : (!readonly ? `<button class="settle-mark-paid btn-secondary text-xs py-1 px-2 flex-shrink-0"
                data-from="${esc(t.from)}" data-to="${esc(t.to)}" data-amount="${t.amount}">Mark Paid</button>` : '')}
        </div>`;
      }).join('')}
    </div>
    ${paid.length > 0 ? `<button id="settle-reset" class="mt-4 text-xs text-gray-400 hover:text-gray-600 underline block">Reset all settlements</button>` : ''}`;

  container.querySelectorAll('.settle-mark-paid').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!trip.paidSettlements) trip.paidSettlements = [];
      trip.paidSettlements.push({ from: btn.dataset.from, to: btn.dataset.to, amount: parseFloat(btn.dataset.amount) });
      saveTrip(trip); renderSettleContent(calculateSettlements());
    });
  });
  container.querySelector('#settle-reset')?.addEventListener('click', () => { trip.paidSettlements = []; saveTrip(trip); renderSettleContent(calculateSettlements()); });
}

// ── Init ──────────────────────────────────────────────────────────────────────

renderHeader();
renderPackingList();
renderItinerary();
renderInfo();
renderExpenses();
</script>
