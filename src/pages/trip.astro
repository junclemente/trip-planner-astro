    ${infoRow('Origin', trip.origin?.city || trip.departFrom, 'Not set')}
    ${infoRow('Dates', formatDateRange(trip.startDate, trip.endDate))}
    ${infoRow('Nights', String(trip.nights))}
    ${infoRow('Template', TEMPLATES[trip.template]?.label ?? trip.template)}
    ${trip.notes ? `<div class="mt-2 pt-2 border-t border-gray-50"><p class="text-xs text-gray-500 mb-0.5">Notes</p><p class="text-sm text-gray-800">${esc(trip.notes)}</p></div>` : ''}
  </div>`;
