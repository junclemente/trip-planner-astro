---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Trip" page="trip">

  <!-- Header -->
  <header class="sticky top-0 z-30 bg-white border-b border-gray-100 shadow-sm">
    <div class="flex items-center gap-3 px-4 py-3 max-w-lg mx-auto">
      <a id="back-btn" href="#" class="text-gray-500 hover:text-gray-700 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </a>
      <div class="flex-1 min-w-0">
        <h1 id="trip-title" class="font-bold text-gray-900 truncate">Loading…</h1>
        <p id="trip-subtitle" class="text-xs text-gray-500 truncate"></p>
      </div>
      <div id="trip-actions" class="flex items-center gap-1"></div>
    </div>

    <!-- Tabs -->
    <div class="flex border-t border-gray-100 max-w-lg mx-auto">
      <button class="tab-btn active" data-tab="packing">Packing List</button>
      <button class="tab-btn" data-tab="itinerary">Itinerary</button>
      <button class="tab-btn" data-tab="info">Info</button>
    </div>
  </header>

  <!-- Tab panels -->
  <main class="max-w-lg mx-auto">
    <div id="tab-packing"   class="tab-panel"></div>
    <div id="tab-itinerary" class="tab-panel hidden"></div>
    <div id="tab-info"      class="tab-panel hidden px-4 py-4 space-y-4"></div>
  </main>

  <!-- ── Add / Edit Item Modal ── -->
  <div id="modal-item" class="modal-overlay hidden">
    <div class="modal-box">
      <div class="flex items-center justify-between p-4 border-b">
        <h2 id="modal-item-title" class="text-lg font-bold">Add Item</h2>
        <button class="close-modal text-gray-400 hover:text-gray-600 text-2xl leading-none"
                data-modal="modal-item">&times;</button>
      </div>
      <form id="form-item" class="p-4 space-y-3">
        <input type="hidden" id="item-edit-id" />
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Item *</label>
          <input id="item-text" type="text" class="input" placeholder="e.g. Sunscreen" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
          <select id="item-category" class="input">
            <option value="">— None —</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Priority</label>
          <select id="item-priority" class="input">
            <option value="">— None —</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Quantity</label>
          <input id="item-qty" type="number" min="1" class="input" placeholder="Leave blank if N/A" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Needed on Day <span class="text-gray-400 font-normal text-xs">(optional, info only)</span>
          </label>
          <input id="item-needed-day" type="text" class="input" placeholder="e.g. Day 1, Day 3 – Hotel check-in" />
        </div>
        <div class="flex gap-3 pt-1">
          <button type="button" class="close-modal btn-secondary flex-1" data-modal="modal-item">Cancel</button>
          <button type="submit" class="btn-primary flex-1">Save</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Add / Edit Event Modal ── -->
  <div id="modal-event" class="modal-overlay hidden">
    <div class="modal-box">
      <div class="flex items-center justify-between p-4 border-b">
        <h2 id="modal-event-title" class="text-lg font-bold">Add Event</h2>
        <button class="close-modal text-gray-400 hover:text-gray-600 text-2xl leading-none"
                data-modal="modal-event">&times;</button>
      </div>
      <form id="form-event" class="p-4 space-y-3">
        <input type="hidden" id="event-edit-id" />
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Event Title *</label>
          <input id="event-title" type="text" class="input" placeholder="e.g. Flight check-in" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Day</label>
          <select id="event-day" class="input"></select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Time</label>
          <input id="event-time" type="time" class="input" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
          <textarea id="event-notes" class="input resize-none" rows="2" placeholder="Optional details"></textarea>
        </div>
        <div class="flex gap-3 pt-1">
          <button type="button" class="close-modal btn-secondary flex-1" data-modal="modal-event">Cancel</button>
          <button type="submit" class="btn-primary flex-1">Save</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Suggest Itinerary Events Modal ── -->
  <div id="modal-suggest-events" class="modal-overlay hidden">
    <div class="modal-box max-w-sm">
      <div class="flex items-center justify-between p-4 border-b">
        <h2 class="text-lg font-bold">Add to Itinerary?</h2>
        <button class="close-modal text-gray-400 hover:text-gray-600 text-2xl leading-none"
                data-modal="modal-suggest-events">&times;</button>
      </div>
      <div class="p-4">
        <p class="text-sm text-gray-600 mb-3">Based on your info, add these events to your itinerary?</p>
        <div id="suggest-events-list" class="space-y-2.5 mb-4"></div>
        <div class="flex gap-3">
          <button id="suggest-events-skip" class="btn-secondary flex-1">Skip</button>
          <button id="suggest-events-add" class="btn-primary flex-1">Add Selected</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Confirm Modal ── -->
  <div id="modal-confirm" class="modal-overlay hidden">
    <div class="modal-box max-w-sm">
      <div class="p-6 text-center">
        <div class="text-4xl mb-3" id="confirm-icon">⚠️</div>
        <h3 id="confirm-title" class="text-lg font-bold mb-2">Are you sure?</h3>
        <p id="confirm-msg" class="text-sm text-gray-600 mb-6"></p>
        <div class="flex gap-3">
          <button id="confirm-cancel" class="btn-secondary flex-1">Cancel</button>
          <button id="confirm-ok" class="btn-danger flex-1">Confirm</button>
        </div>
      </div>
    </div>
  </div>

</Layout>

<script>
import {
  genId, getTrip, saveTrip, deleteTrip, archiveTrip, unarchiveTrip, exportTrip,
  getProfile, duplicateTrip,
} from '../scripts/store.js';
import {
  getAllCategories, getAllPriorities, getCategoryColor, getPriorityColor,
  getCategoryLabel, getPriorityLabel, migrateChecklistItems,
  calcClothing, formatDate, formatDateRange, buildDays, TEMPLATES,
} from '../scripts/templates.js';

const BASE = import.meta.env.BASE_URL;
const params = new URLSearchParams(window.location.search);
const tripId = params.get('id');

if (!tripId) { location.replace(BASE); throw 0; }
let trip = getTrip(tripId);
if (!trip) { location.replace(BASE); throw 0; }

if (migrateChecklistItems(trip.checklistItems ?? [])) saveTrip(trip);

let profile = getProfile();
const readonly = trip.status === 'archived';

let activeCategory = null;
let activePriority = null;
let editingSection = null; // 'basics' | 'flight' | 'hotel' | 'transport'

// ── Helpers ──────────────────────────────────────────────────────────────────

function esc(s) {
  const d = document.createElement('div');
  d.textContent = String(s ?? '');
  return d.innerHTML;
}

function reload() {
  trip = getTrip(tripId);
  profile = getProfile();
  renderHeader();
  renderPackingList();
  renderItinerary();
  renderInfo();
}

// ── Tabs ─────────────────────────────────────────────────────────────────────

const tabBtns = document.querySelectorAll('.tab-btn[data-tab]');
const tabPanels = document.querySelectorAll('.tab-panel');
let currentTab = 'packing';

tabBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    if (btn.dataset.tab !== 'packing') {
      activeCategory = null;
      activePriority = null;
    }
    currentTab = btn.dataset.tab;
    tabBtns.forEach(b => b.classList.toggle('active', b.dataset.tab === currentTab));
    tabPanels.forEach(p => p.classList.toggle('hidden', p.id !== `tab-${currentTab}`));
  });
});

// ── Modals ───────────────────────────────────────────────────────────────────

function openModal(id) { document.getElementById(id)?.classList.remove('hidden'); }
function closeModal(id) { document.getElementById(id)?.classList.add('hidden'); }

document.querySelectorAll('.close-modal').forEach(btn => {
  btn.addEventListener('click', () => closeModal(btn.dataset.modal));
});
document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(overlay.id); });
});
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    ['modal-item', 'modal-event', 'modal-confirm', 'modal-suggest-events'].forEach(closeModal);
  }
});

function confirmAction(icon, title, msg, okLabel, okClass, onOk) {
  document.getElementById('confirm-icon').textContent = icon;
  document.getElementById('confirm-title').textContent = title;
  document.getElementById('confirm-msg').textContent = msg;
  const okBtn = document.getElementById('confirm-ok');
  okBtn.textContent = okLabel;
  okBtn.className = okClass + ' flex-1';
  openModal('modal-confirm');
  const handler = () => {
    closeModal('modal-confirm');
    onOk();
    okBtn.removeEventListener('click', handler);
  };
  okBtn.addEventListener('click', handler);
  document.getElementById('confirm-cancel').onclick = () => {
    closeModal('modal-confirm');
    okBtn.removeEventListener('click', handler);
  };
}

// ── Header ───────────────────────────────────────────────────────────────────

function renderHeader() {
  document.getElementById('back-btn').href = BASE;
  document.getElementById('trip-title').textContent = trip.name;
  document.getElementById('trip-subtitle').textContent =
    `${trip.destination}${trip.departFrom ? ' · from ' + trip.departFrom : ''} · ${formatDateRange(trip.startDate, trip.endDate)}`;

  const actions = document.getElementById('trip-actions');
  if (readonly) {
    actions.innerHTML = `<span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded-full font-medium">Archived</span>`;
    return;
  }
  actions.innerHTML = `
    <button id="btn-export-trip" class="btn-ghost p-1.5" title="Export JSON">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
      </svg>
    </button>
    <button id="btn-archive-trip" class="btn-ghost p-1.5" title="Archive Trip">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
      </svg>
    </button>`;

  document.getElementById('btn-export-trip').addEventListener('click', () => exportTrip(trip));
  document.getElementById('btn-archive-trip').addEventListener('click', () => {
    confirmAction('📦', 'Archive this trip?',
      'The trip will be frozen as a read-only snapshot in the Archive.',
      'Archive', 'btn-secondary',
      () => { archiveTrip(tripId); window.showToast?.('Trip archived'); setTimeout(() => location.replace(`${BASE}archive/`), 600); });
  });
}

// ── Packing List ─────────────────────────────────────────────────────────────

function buildFilterBar(items) {
  const allCats = getAllCategories(profile.customCategories);
  const allPris = getAllPriorities(profile.customPriorities);

  const catCounts = {}, priCounts = {};
  items.forEach(item => {
    if (item.category) catCounts[item.category] = (catCounts[item.category] ?? 0) + 1;
    if (item.priority) priCounts[item.priority] = (priCounts[item.priority] ?? 0) + 1;
  });

  const catIds = Object.keys(catCounts);
  const priIds = Object.keys(priCounts);
  if (catIds.length === 0 && priIds.length === 0) return '';

  const catBtn = id => {
    const tag = allCats.find(c => c.id === id);
    if (!tag) return '';
    const isActive = activeCategory === id;
    const cls = isActive ? tag.color + ' ring-1 ring-inset ring-current' : 'bg-gray-100 text-gray-600';
    return `<button class="filter-cat text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0 transition-colors ${cls}" data-cat="${esc(id)}">${esc(tag.label)} <span class="font-normal">${catCounts[id]}</span></button>`;
  };
  const priBtn = id => {
    const tag = allPris.find(p => p.id === id);
    if (!tag) return '';
    const isActive = activePriority === id;
    const cls = isActive ? tag.color + ' ring-1 ring-inset ring-current' : 'bg-gray-100 text-gray-600';
    return `<button class="filter-pri text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0 transition-colors ${cls}" data-pri="${esc(id)}">${esc(tag.label)} <span class="font-normal">${priCounts[id]}</span></button>`;
  };

  const hasFilter = activeCategory !== null || activePriority !== null;
  const filteredCount = items.filter(i =>
    (activeCategory === null || i.category === activeCategory) &&
    (activePriority === null || i.priority === activePriority)
  ).length;

  return `
    <div class="px-4 pb-2 space-y-1.5">
      ${catIds.length > 0 ? `
      <div class="flex items-center gap-1.5 overflow-x-auto pb-0.5" style="scrollbar-width:none;-webkit-overflow-scrolling:touch">
        <button class="filter-cat text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0 transition-colors ${activeCategory === null ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600'}" data-cat="">All</button>
        ${catIds.map(catBtn).join('')}
      </div>` : ''}
      ${priIds.length > 0 ? `
      <div class="flex items-center gap-1.5 overflow-x-auto pb-0.5" style="scrollbar-width:none;-webkit-overflow-scrolling:touch">
        <button class="filter-pri text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0 transition-colors ${activePriority === null ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600'}" data-pri="">All</button>
        ${priIds.map(priBtn).join('')}
      </div>` : ''}
      ${hasFilter ? `<p class="text-xs text-indigo-600 font-medium">${filteredCount} item${filteredCount !== 1 ? 's' : ''} shown</p>` : ''}
    </div>`;
}

function renderPackingList() {
  const panel = document.getElementById('tab-packing');
  const items = trip.checklistItems ?? [];
  const total = items.length;
  const checked = items.filter(i => i.checked).length;
  const pct = total === 0 ? 0 : Math.round((checked / total) * 100);

  const visibleItems = items.filter(item =>
    (activeCategory === null || item.category === activeCategory) &&
    (activePriority === null || item.priority === activePriority)
  );

  panel.innerHTML = `
    <div class="sticky top-[97px] bg-white border-b border-gray-100 z-20">
      <div class="px-4 py-2 flex items-center justify-between gap-4">
        <div class="flex-1">
          <div class="flex justify-between text-xs text-gray-500 mb-1">
            <span>${checked}/${total} packed</span><span>${pct}%</span>
          </div>
          <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
            <div class="h-full bg-indigo-500 rounded-full transition-all duration-300" style="width:${pct}%"></div>
          </div>
        </div>
        ${!readonly ? `<button id="btn-add-item-top" class="btn-primary text-xs py-1.5 px-3 flex-shrink-0">+ Add Item</button>` : ''}
      </div>
      ${total > 0 ? buildFilterBar(items) : ''}
    </div>
    <ul>
      ${visibleItems.map(item => renderItemRow(item)).join('')}
      ${visibleItems.length === 0 && total > 0 ? `<li class="px-4 py-10 text-center text-sm text-gray-400 italic">No items match the active filter</li>` : ''}
      ${total === 0 ? `<li class="px-4 py-12 text-center text-sm text-gray-400">No items yet — tap + Add Item to get started.</li>` : ''}
    </ul>`;

  panel.querySelector('#btn-add-item-top')?.addEventListener('click', () => openItemModal());
  panel.querySelectorAll('[data-toggle]').forEach(cb => cb.addEventListener('change', () => toggleItem(cb.dataset.toggle)));
  panel.querySelectorAll('[data-edit-item]').forEach(btn => btn.addEventListener('click', () => openItemModal(btn.dataset.editItem)));
  panel.querySelectorAll('[data-del-item]').forEach(btn => btn.addEventListener('click', () => deleteItem(btn.dataset.delItem)));
  panel.querySelectorAll('.filter-cat').forEach(btn => btn.addEventListener('click', () => { activeCategory = btn.dataset.cat || null; renderPackingList(); }));
  panel.querySelectorAll('.filter-pri').forEach(btn => btn.addEventListener('click', () => { activePriority = btn.dataset.pri || null; renderPackingList(); }));
  panel.querySelectorAll('[data-clothing-dec]').forEach(btn => btn.addEventListener('click', () => adjustClothingQty(btn.dataset.clothingDec, -1)));
  panel.querySelectorAll('[data-clothing-inc]').forEach(btn => btn.addEventListener('click', () => adjustClothingQty(btn.dataset.clothingInc, 1)));
}

function renderItemRow(item) {
  const catTag = item.category
    ? `<span class="badge ${getCategoryColor(item.category, profile.customCategories)} ml-1">${esc(getCategoryLabel(item.category, profile.customCategories))}</span>` : '';
  const priTag = item.priority
    ? `<span class="badge ${getPriorityColor(item.priority, profile.customPriorities)} ml-1">${esc(getPriorityLabel(item.priority, profile.customPriorities))}</span>` : '';
  const neededDay = item.neededOnDay
    ? `<span class="text-xs text-gray-400 block mt-0.5">📅 ${esc(item.neededOnDay)}</span>` : '';

  const qtyBlock = item.isClothing
    ? `<div class="flex items-center gap-1 flex-shrink-0 ml-1">
        ${!readonly ? `<button data-clothing-dec="${esc(item.id)}" class="w-6 h-6 rounded-full bg-gray-100 hover:bg-orange-100 text-gray-600 hover:text-orange-700 text-sm font-bold flex items-center justify-center transition-colors leading-none">−</button>` : ''}
        <span class="text-sm font-semibold text-orange-700 min-w-[1.25rem] text-center">${item.quantity ?? 0}</span>
        ${!readonly ? `<button data-clothing-inc="${esc(item.id)}" class="w-6 h-6 rounded-full bg-gray-100 hover:bg-orange-100 text-gray-600 hover:text-orange-700 text-sm font-bold flex items-center justify-center transition-colors leading-none">+</button>` : ''}
      </div>`
    : (item.quantity != null ? `<span class="text-xs text-gray-400 ml-1 flex-shrink-0">×${item.quantity}</span>` : '');

  const editBtn = !readonly ? `
    <button data-edit-item="${esc(item.id)}"
            class="opacity-0 group-hover:opacity-100 text-gray-300 hover:text-indigo-500 transition-all p-0.5" title="Edit">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
      </svg>
    </button>
    <button data-del-item="${esc(item.id)}"
            class="opacity-0 group-hover:opacity-100 text-gray-300 hover:text-red-400 transition-all p-0.5 text-base leading-none" title="Delete">×</button>` : '';

  return `
    <li class="group flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 border-b border-gray-50 transition-colors ${item.checked ? 'opacity-60' : ''}">
      ${!readonly ? `<input type="checkbox" ${item.checked ? 'checked' : ''} data-toggle="${esc(item.id)}" class="h-4 w-4 rounded text-indigo-600 cursor-pointer flex-shrink-0">` : `
      <div class="w-4 h-4 rounded border-2 ${item.checked ? 'bg-indigo-600 border-indigo-600' : 'border-gray-300'} flex-shrink-0 flex items-center justify-center">
        ${item.checked ? `<svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>` : ''}
      </div>`}
      <div class="flex-1 min-w-0">
        <div class="flex items-center flex-wrap gap-x-0.5">
          <span class="text-sm ${item.checked ? 'line-through text-gray-400' : 'text-gray-800'}">${esc(item.text)}</span>
          ${!item.isClothing ? qtyBlock : ''}
          ${catTag}${priTag}
        </div>
        ${neededDay}
      </div>
      ${item.isClothing ? qtyBlock : ''}
      <div class="flex items-center gap-0.5">${editBtn}</div>
    </li>`;
}

function adjustClothingQty(itemId, delta) {
  const item = trip.checklistItems.find(i => i.id === itemId);
  if (!item?.isClothing) return;
  item.quantity = Math.max(0, (item.quantity ?? 0) + delta);
  if (!trip.clothingOverrides) trip.clothingOverrides = {};
  trip.clothingOverrides[item.clothingType] = item.quantity;
  saveTrip(trip);
  renderPackingList();
}

function toggleItem(itemId) {
  const item = trip.checklistItems.find(i => i.id === itemId);
  if (!item) return;
  item.checked = !item.checked;
  saveTrip(trip);
  renderPackingList();
}

function deleteItem(itemId) {
  trip.checklistItems = trip.checklistItems.filter(i => i.id !== itemId);
  saveTrip(trip);
  renderPackingList();
  window.showToast?.('Item removed');
}

// ── Item Modal ───────────────────────────────────────────────────────────────

function populateTagSelects(selectedCategory = null, selectedPriority = null) {
  const allCats = getAllCategories(profile.customCategories);
  const allPris = getAllPriorities(profile.customPriorities);

  document.getElementById('item-category').innerHTML =
    `<option value="">— None —</option>` +
    allCats.map(c => `<option value="${esc(c.id)}" ${c.id === selectedCategory ? 'selected' : ''}>${esc(c.label)}</option>`).join('');

  document.getElementById('item-priority').innerHTML =
    `<option value="">— None —</option>` +
    allPris.map(p => `<option value="${esc(p.id)}" ${p.id === selectedPriority ? 'selected' : ''}>${esc(p.label)}</option>`).join('');
}

function openItemModal(editItemId = null) {
  document.getElementById('form-item').reset();
  document.getElementById('item-edit-id').value = '';
  document.getElementById('modal-item-title').textContent = editItemId ? 'Edit Item' : 'Add Item';

  if (editItemId) {
    const item = trip.checklistItems.find(i => i.id === editItemId);
    if (item) {
      document.getElementById('item-edit-id').value = item.id;
      document.getElementById('item-text').value = item.text;
      document.getElementById('item-qty').value = item.quantity ?? '';
      document.getElementById('item-needed-day').value = item.neededOnDay ?? '';
      populateTagSelects(item.category, item.priority);
    }
  } else {
    populateTagSelects();
  }

  openModal('modal-item');
  setTimeout(() => document.getElementById('item-text').focus(), 50);
}

document.getElementById('form-item').addEventListener('submit', e => {
  e.preventDefault();
  const editId = document.getElementById('item-edit-id').value;
  const text = document.getElementById('item-text').value.trim();
  const category = document.getElementById('item-category').value || null;
  const priority = document.getElementById('item-priority').value || null;
  const qtyVal = document.getElementById('item-qty').value;
  const quantity = qtyVal ? parseInt(qtyVal) : null;
  const neededOnDay = document.getElementById('item-needed-day').value.trim() || null;

  if (editId) {
    const item = trip.checklistItems.find(i => i.id === editId);
    if (item) Object.assign(item, { text, category, priority, quantity, neededOnDay });
  } else {
    trip.checklistItems.push({ id: genId(), tripId, dayId: null, text, category, priority, checked: false, quantity, neededOnDay });
  }
  saveTrip(trip);
  closeModal('modal-item');
  renderPackingList();
  window.showToast?.(editId ? 'Item updated' : 'Item added');
});

// ── Itinerary ────────────────────────────────────────────────────────────────

function renderItinerary() {
  const panel = document.getElementById('tab-itinerary');
  const events = trip.itineraryEvents ?? [];
  const byDay = {};
  trip.days.forEach(d => (byDay[d.id] = []));
  events.forEach(ev => { if (byDay[ev.dayId]) byDay[ev.dayId].push(ev); });
  trip.days.forEach(d => byDay[d.id].sort((a, b) => (a.time ?? '').localeCompare(b.time ?? '')));

  panel.innerHTML = `
    ${!readonly ? `
    <div class="px-4 py-3 border-b border-gray-100 flex justify-end">
      <button id="btn-add-event-top" class="btn-primary text-xs py-1.5 px-3">+ Add Event</button>
    </div>` : ''}
    ${trip.days.map(day => {
      const dayEvents = byDay[day.id] ?? [];
      return `
        <div class="mb-2">
          <div class="flex items-center justify-between px-4 py-2 bg-gray-50 border-b border-gray-100">
            <div>
              <span class="text-sm font-semibold text-gray-800">${esc(day.label)}</span>
              <span class="text-xs text-gray-400 ml-1.5">${formatDate(day.date)}</span>
            </div>
            ${!readonly ? `<button class="add-event-day text-xs text-indigo-600 hover:text-indigo-800 font-medium" data-day-id="${esc(day.id)}">+ Event</button>` : ''}
          </div>
          <div class="divide-y divide-gray-50">
            ${dayEvents.map(ev => renderEventRow(ev)).join('')}
            ${dayEvents.length === 0 ? `<div class="px-4 py-3 text-xs text-gray-400 italic">No events</div>` : ''}
          </div>
        </div>`;
    }).join('')}`;

  panel.querySelector('#btn-add-event-top')?.addEventListener('click', () => openEventModal());
  panel.querySelectorAll('.add-event-day').forEach(btn => btn.addEventListener('click', () => openEventModal(btn.dataset.dayId)));
  panel.querySelectorAll('[data-edit-event]').forEach(btn => btn.addEventListener('click', () => openEventModal(null, btn.dataset.editEvent)));
  panel.querySelectorAll('[data-del-event]').forEach(btn => btn.addEventListener('click', () => deleteEvent(btn.dataset.delEvent)));
}

function renderEventRow(ev) {
  const editDel = !readonly ? `
    <div class="flex gap-1 ml-2 opacity-0 group-hover:opacity-100 transition-opacity">
      <button data-edit-event="${esc(ev.id)}" class="btn-ghost p-1 text-xs" title="Edit">✏️</button>
      <button data-del-event="${esc(ev.id)}" class="btn-ghost p-1 text-xs text-red-400 hover:text-red-600" title="Delete">×</button>
    </div>` : '';
  return `
    <div class="group flex gap-3 px-4 py-3 hover:bg-gray-50 transition-colors">
      <div class="flex-shrink-0 w-14 text-right">
        <span class="text-xs font-mono text-indigo-600 font-medium">${ev.time ? esc(ev.time) : '—'}</span>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-gray-900">${esc(ev.title)}</p>
        ${ev.notes ? `<p class="text-xs text-gray-500 mt-0.5">${esc(ev.notes)}</p>` : ''}
      </div>
      ${editDel}
    </div>`;
}

function deleteEvent(eventId) {
  trip.itineraryEvents = trip.itineraryEvents.filter(e => e.id !== eventId);
  saveTrip(trip);
  renderItinerary();
  window.showToast?.('Event removed');
}

// ── Event Modal ──────────────────────────────────────────────────────────────

function openEventModal(preselectedDayId = null, editEventId = null) {
  document.getElementById('form-event').reset();
  document.getElementById('event-edit-id').value = '';
  document.getElementById('modal-event-title').textContent = editEventId ? 'Edit Event' : 'Add Event';

  const daySelect = document.getElementById('event-day');
  daySelect.innerHTML = trip.days.map(d =>
    `<option value="${esc(d.id)}" ${d.id === preselectedDayId ? 'selected' : ''}>${esc(d.label)}</option>`
  ).join('');

  if (editEventId) {
    const ev = trip.itineraryEvents.find(e => e.id === editEventId);
    if (ev) {
      document.getElementById('event-edit-id').value = ev.id;
      document.getElementById('event-title').value = ev.title;
      document.getElementById('event-day').value = ev.dayId;
      document.getElementById('event-time').value = ev.time ?? '';
      document.getElementById('event-notes').value = ev.notes ?? '';
    }
  }
  openModal('modal-event');
  setTimeout(() => document.getElementById('event-title').focus(), 50);
}

document.getElementById('form-event').addEventListener('submit', e => {
  e.preventDefault();
  const editId = document.getElementById('event-edit-id').value;
  const title = document.getElementById('event-title').value.trim();
  const dayId = document.getElementById('event-day').value;
  const time = document.getElementById('event-time').value;
  const notes = document.getElementById('event-notes').value.trim();

  if (editId) {
    const ev = trip.itineraryEvents.find(e => e.id === editId);
    if (ev) Object.assign(ev, { title, dayId, time, notes });
  } else {
    if (!trip.itineraryEvents) trip.itineraryEvents = [];
    trip.itineraryEvents.push({ id: genId(), tripId, dayId, time, title, notes });
  }
  saveTrip(trip);
  closeModal('modal-event');
  renderItinerary();
  window.showToast?.(editId ? 'Event updated' : 'Event added');
});

// ── Info Tab ──────────────────────────────────────────────────────────────────

