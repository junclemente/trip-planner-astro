      confirmAction('🗺️', 'Remove destination?', `Remove "${d?.city || 'this destination'}" from the trip?`, 'Remove', 'btn-danger',
        () => {
          trip.destinations = (trip.destinations ?? []).filter(d => d.id !== btn.dataset.destId);
          autoAdjustDestinationDates(trip);
          recalcDatesFromDests();
          saveTrip(trip); renderHeader(); renderItinerary(); renderInfo(); renderPackingList();
        });
