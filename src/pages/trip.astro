function renderInfoDestinations() {
  const dests = trip.destinations ?? [];
  function destCard(d) {
    const plugStr = d.plugTypes?.length ? `Type ${d.plugTypes.join('/')}` : '';
    const voltageStr = d.voltage || '';
    const powerStr = [plugStr, voltageStr].filter(Boolean).join(' · ');
    const currStr = d.currencyCode ? `${d.currency || ''} (${d.currencyCode})` : (d.currency || '');
    const dateStr = (d.arrivalDate && d.departureDate)
      ? `${formatDate(d.arrivalDate)} – ${formatDate(d.departureDate)}`
      : d.arrivalDate ? `From ${formatDate(d.arrivalDate)}` : '';
    const notes = [d.currencyNotes, d.atmNotes, d.cardNotes].filter(Boolean);
    return `<div class="border border-gray-200 rounded-lg p-3 mb-2">
      <div class="flex items-start justify-between gap-2">
        <div class="min-w-0">
          <p class="text-sm font-semibold text-gray-800">${d.city ? esc(d.city) + (d.country ? ', ' + esc(d.country) : '') : esc(d.country)}</p>
          ${dateStr ? `<p class="text-xs text-gray-500 mt-0.5">${esc(dateStr)}</p>` : ''}
          ${currStr ? `<p class="text-xs text-gray-400 mt-0.5">${esc(currStr)}${powerStr ? ' · ' + esc(powerStr) : ''}</p>` : powerStr ? `<p class="text-xs text-gray-400 mt-0.5">${esc(powerStr)}</p>` : ''}
          ${parseInt(d.voltage) >= 220 ? `<p class="text-xs text-amber-600 mt-0.5">⚡ ${esc(d.voltage)} — check device compatibility</p>` : ''}
        </div>
        ${!readonly ? `<div class="flex gap-1 flex-shrink-0">
          <button class="edit-dest btn-ghost p-1 text-xs" data-dest-id="${esc(d.id)}" title="Edit">✏️</button>
          <button class="del-dest btn-ghost p-1 text-xs text-red-400 hover:text-red-600" data-dest-id="${esc(d.id)}" title="Delete">×</button>
        </div>` : ''}
      </div>
      ${notes.length ? `<div class="mt-2 pt-2 border-t border-gray-100 space-y-0.5">${notes.map(n => `<p class="text-xs text-gray-600">${esc(n)}</p>`).join('')}</div>` : ''}
    </div>`;
  }
  return `<div class="card p-4">
    <div class="flex items-center justify-between mb-3">
      <h3 class="font-semibold text-gray-700 text-sm uppercase tracking-wide">Destinations</h3>
      ${!readonly ? `<button id="btn-add-dest" class="btn-primary text-sm py-1.5 px-3">+ Add</button>` : ''}
    </div>
    ${dests.length > 0
      ? dests.map(destCard).join('')
      : `<p class="text-sm text-gray-400 italic">No destinations added. Use + Add to add your first stop.</p>`}
  </div>`;
}

function renderInfoDocuments() {
  const docs = trip.travelDocuments ?? {};
  const passport = docs.passport ?? {};
  const insurance = docs.insurance ?? {};
  const customReminders = docs.customReminders ?? [];
  const dismissed = new Set(docs.dismissedVisaReminders ?? []);
  const dests = trip.destinations ?? [];

  // Passport expiry warning
  let passportWarn = '';
  if (passport.expiryDate && trip.endDate) {
    const expiry = new Date(passport.expiryDate + 'T12:00:00');
    const tripEnd = new Date(trip.endDate + 'T12:00:00');
    const sixMonthsAfterTrip = new Date(tripEnd);
    sixMonthsAfterTrip.setMonth(sixMonthsAfterTrip.getMonth() + 6);
    if (expiry < sixMonthsAfterTrip) {
      const daysToExpiry = Math.round((expiry - tripEnd) / 86400000);
      passportWarn = daysToExpiry < 0
        ? `<p class="text-xs text-red-600 bg-red-50 rounded p-2 mt-1">⚠️ Passport expired before trip end! Renew immediately.</p>`
        : `<p class="text-xs text-amber-700 bg-amber-50 rounded p-2 mt-1">⚠️ Passport expires within 6 months of trip end. Many countries require 6 months validity. Consider renewing.</p>`;
    }
  }

  // Visa / entry requirements from destinations
  const profile = getProfile();
  const homeCountryCode = profile.homeBase?.countryCode || 'US';
  const visaItems = dests
    .filter(d => d.countryCode && d.countryCode !== homeCountryCode)
    .map(d => {
      const country = getCountry(d.countryCode);
      return country ? { code: d.countryCode, country: d.country || country.name, info: country.visaInfo?.[homeCountryCode] ?? 'Check entry requirements for this country.' } : null;
    })
    .filter(Boolean);

  if (editingSection === 'documents') {
    return `<div class="card p-4">
      <h3 class="font-semibold text-gray-700 text-sm uppercase tracking-wide mb-3">Travel Documents</h3>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Passport</p>
      <div class="space-y-2 mb-4">
        <div><label class="block text-xs text-gray-500 mb-1">Passport Holder Name</label><input id="doc-passport-name" class="input text-sm" value="${esc(passport.name ?? '')}" placeholder="Full name as on passport" /></div>
        <div><label class="block text-xs text-gray-500 mb-1">Expiry Date</label><input id="doc-passport-expiry" type="date" class="input text-sm" value="${passport.expiryDate ?? ''}" /></div>
      </div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Travel Insurance</p>
      <div class="space-y-2 mb-4">
        <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer select-none">
          <input type="checkbox" id="doc-insurance-check" class="h-4 w-4 rounded text-indigo-600" ${insurance.hasInsurance ? 'checked' : ''} />
          I have travel insurance
        </label>
        <div id="doc-insurance-fields" class="${insurance.hasInsurance ? '' : 'hidden'} space-y-2">
          <div><label class="block text-xs text-gray-500 mb-1">Provider</label><input id="doc-ins-provider" class="input text-sm" value="${esc(insurance.provider ?? '')}" placeholder="e.g. World Nomads" /></div>
          <div><label class="block text-xs text-gray-500 mb-1">Policy Number</label><input id="doc-ins-policy" class="input text-sm" value="${esc(insurance.policyNumber ?? '')}" /></div>
          <div><label class="block text-xs text-gray-500 mb-1">Coverage Notes</label><textarea id="doc-ins-notes" class="input text-sm resize-none" rows="2">${esc(insurance.notes ?? '')}</textarea></div>
        </div>
      </div>
      <div class="flex gap-2 mt-3">
        <button class="info-cancel btn-secondary flex-1 text-sm py-2">Cancel</button>
        <button class="info-save btn-primary flex-1 text-sm py-2" data-section="documents">Save</button>
      </div>
    </div>`;
  }

  const hasPassport = passport.name || passport.expiryDate;
  const hasInsurance = insurance.hasInsurance;
  return `<div class="card p-4">
    <div class="flex items-center justify-between mb-3">
      <h3 class="font-semibold text-gray-700 text-sm uppercase tracking-wide">Travel Documents</h3>
      ${!readonly ? `<button class="info-edit text-xs text-indigo-600 font-medium hover:text-indigo-800" data-section="documents">Edit</button>` : ''}
    </div>
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">Passport</p>
    ${hasPassport ? `
      ${infoRow('Name', passport.name, 'Not set')}
      ${infoRow('Expires', passport.expiryDate ? new Date(passport.expiryDate + 'T12:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : null, 'Not set')}
      ${passportWarn}
    ` : `<p class="text-sm text-gray-400 italic mb-3">No passport info. Tap Edit to add.</p>`}
    ${visaItems.length > 0 ? `
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mt-3 mb-1.5">Entry Requirements (US Passport)</p>
      <div class="space-y-2">
        ${visaItems.map(v => `
          <div class="flex items-start gap-2 p-2 rounded-lg ${dismissed.has(v.code) ? 'bg-gray-50 opacity-50' : 'bg-blue-50'}">
            <input type="checkbox" class="visa-dismiss-check mt-0.5 h-4 w-4 rounded text-indigo-600 flex-shrink-0"
                   data-country-code="${esc(v.code)}" ${dismissed.has(v.code) ? 'checked' : ''} />
            <div class="min-w-0">
              <p class="text-xs font-semibold text-gray-700">${esc(v.country)}</p>
              <p class="text-xs text-gray-600 mt-0.5">${esc(v.info)}</p>
            </div>
          </div>`).join('')}
      </div>` : ''}
    ${customReminders.length > 0 ? `
      <div class="mt-3 space-y-1.5">
        ${customReminders.map(r => `
          <div class="flex items-center gap-2">
            <input type="checkbox" class="custom-reminder-check h-4 w-4 rounded text-indigo-600"
                   data-reminder-id="${esc(r.id)}" ${r.done ? 'checked' : ''} />
            <span class="text-sm ${r.done ? 'line-through text-gray-400' : 'text-gray-700'} flex-1">${esc(r.text)}</span>
            ${!readonly ? `<button class="del-reminder text-gray-300 hover:text-red-400 text-lg leading-none" data-reminder-id="${esc(r.id)}">×</button>` : ''}
          </div>`).join('')}
      </div>` : ''}
    ${!readonly ? `<form id="form-custom-reminder" class="flex gap-2 mt-3">
      <input id="custom-reminder-input" type="text" class="input text-sm flex-1" placeholder="Add custom reminder..." />
      <button type="submit" class="btn-secondary text-sm px-3">Add</button>
    </form>` : ''}
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mt-3 mb-1.5">Travel Insurance</p>
    ${hasInsurance ? `
      ${infoRow('Status', 'Covered')}
      ${insurance.provider ? infoRow('Provider', insurance.provider) : ''}
      ${insurance.policyNumber ? infoRow('Policy #', insurance.policyNumber) : ''}
      ${insurance.notes ? `<p class="text-xs text-gray-500 mt-1">${esc(insurance.notes)}</p>` : ''}
    ` : `<p class="text-sm text-gray-400 italic">No insurance on file. Tap Edit to add.</p>`}
  </div>`;
}

function renderInfoFlight() {
  const fo = trip.flightOut ?? {}, fr = trip.flightReturn ?? {};
  if (editingSection === 'flight') {
    return `<div class="card p-4">
      <h3 class="font-semibold text-gray-700 text-sm uppercase tracking-wide mb-3">Flight Details</h3>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Outbound</p>
      <div class="space-y-2 mb-4">
        <div class="grid grid-cols-2 gap-2">
          <div><label class="block text-xs text-gray-500 mb-1">Airline</label><input id="fo-airline" class="input text-sm" value="${esc(fo.airline ?? '')}" placeholder="Southwest" /></div>
