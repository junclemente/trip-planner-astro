function attachInfoListeners() {
  document.querySelectorAll('.info-edit').forEach(btn => {
    btn.addEventListener('click', () => { editingSection = btn.dataset.section; renderInfo(); });
  });
  document.querySelectorAll('.info-cancel').forEach(btn => {
    btn.addEventListener('click', () => { editingSection = null; renderInfo(); });
  });
  document.querySelectorAll('.info-save').forEach(btn => {
    btn.addEventListener('click', () => saveInfoSection(btn.dataset.section));
  });

  // Live nights recalc while editing dates
  ['info-start', 'info-end'].forEach(id => {
    document.getElementById(id)?.addEventListener('change', () => {
      const s = document.getElementById('info-start')?.value;
      const e = document.getElementById('info-end')?.value;
      const el = document.getElementById('info-nights-calc');
      if (!el || !s || !e) return;
      const n = Math.round((new Date(e + 'T12:00:00') - new Date(s + 'T12:00:00')) / 86400000);
      el.innerHTML = `Nights: <strong>${n >= 0 ? n : '?'}</strong> (auto-calculated)`;
    });
  });

  document.getElementById('info-export')?.addEventListener('click', () => exportTrip(trip));
  document.getElementById('info-duplicate')?.addEventListener('click', () => {
    confirmAction('📋', 'Duplicate this trip?',
      'Creates a copy of the trip with all items unchecked.',
      'Duplicate', 'btn-primary',
      () => {
        const copy = duplicateTrip(tripId);
        window.showToast?.(`"${copy.name}" created`);
        setTimeout(() => { location.href = `${BASE}trip/?id=${copy.id}`; }, 700);
      });
  });
  document.getElementById('info-archive')?.addEventListener('click', () => {
    confirmAction('📦', 'Archive trip?',
      'Frozen read-only snapshot in Archive. You can restore it later.',
      'Archive', 'btn-secondary',
      () => { archiveTrip(tripId); window.showToast?.('Trip archived'); setTimeout(() => location.replace(`${BASE}archive/`), 600); });
  });
  document.getElementById('info-delete')?.addEventListener('click', () => {
    confirmAction('🗑️', `Delete "${trip.name}"?`,
      'This cannot be undone. All data will be permanently removed.',
      'Delete', 'btn-danger',
      () => { deleteTrip(tripId); window.showToast?.('Trip deleted'); setTimeout(() => location.replace(BASE), 600); });
  });
  document.getElementById('info-unarchive')?.addEventListener('click', () => {
    unarchiveTrip(tripId);
    window.showToast?.('Trip restored to active');
    setTimeout(() => location.replace(BASE), 600);
  });
}

function saveInfoSection(section) {
  let suggestSection = null;

  if (section === 'basics') {
    const start = document.getElementById('info-start').value;
    const end = document.getElementById('info-end').value;
    const nights = Math.round((new Date(end + 'T12:00:00') - new Date(start + 'T12:00:00')) / 86400000);
    const nameVal = document.getElementById('info-name').value.trim();
    const destVal = document.getElementById('info-destination').value.trim();

    const datesChanged = start !== trip.startDate || end !== trip.endDate;
    Object.assign(trip, {
      name:        nameVal || trip.name,
      destination: destVal || trip.destination,
      departFrom:  document.getElementById('info-origin').value.trim() || null,
      startDate:   start,
      endDate:     end,
      nights:      nights >= 0 ? nights : trip.nights,
      notes:       document.getElementById('info-notes').value.trim() || null,
    });

    // Rebuild days array when dates change, remapping itinerary events by old date
    if (datesChanged && nights >= 0) {
      const oldDateToDayId = {};
      (trip.days ?? []).forEach(d => { oldDateToDayId[d.date] = d.id; });
      const newDays = buildDays(tripId, start, nights);
      const newDateToDayId = {};
      newDays.forEach(d => { newDateToDayId[d.date] = d.id; });
      (trip.itineraryEvents ?? []).forEach(ev => {
        const oldDay = (trip.days ?? []).find(d => d.id === ev.dayId);
        if (oldDay) {
          ev.dayId = newDateToDayId[oldDay.date] ?? newDays[newDays.length - 1]?.id ?? ev.dayId;
        }
      });
      trip.days = newDays;
    }
  } else if (section === 'flight') {
    const prevFO = JSON.stringify(trip.flightOut ?? {});
    const prevFR = JSON.stringify(trip.flightReturn ?? {});
    trip.flightOut = {
      airline:      document.getElementById('fo-airline').value.trim() || null,
      flightNumber: document.getElementById('fo-number').value.trim() || null,
      departTime:   document.getElementById('fo-depart').value || null,
      arriveTime:   document.getElementById('fo-arrive').value || null,
      confirmation: document.getElementById('fo-confirm').value.trim() || null,
    };
    trip.flightReturn = {
      airline:      document.getElementById('fr-airline').value.trim() || null,
      flightNumber: document.getElementById('fr-number').value.trim() || null,
      departTime:   document.getElementById('fr-depart').value || null,
      arriveTime:   document.getElementById('fr-arrive').value || null,
      confirmation: document.getElementById('fr-confirm').value.trim() || null,
    };
    const anyFlight = (fo) => fo.airline || fo.flightNumber;
    if (anyFlight(trip.flightOut) || anyFlight(trip.flightReturn)) {
      if (JSON.stringify(trip.flightOut) !== prevFO || JSON.stringify(trip.flightReturn) !== prevFR) {
        suggestSection = 'flight';
      }
    }
  } else if (section === 'hotel') {
    const prev = JSON.stringify(trip.hotel ?? {});
    trip.hotel = {
      name:         document.getElementById('h-name').value.trim() || null,
      address:      document.getElementById('h-address').value.trim() || null,
      checkInDate:  document.getElementById('h-checkin-date').value || null,
      checkInTime:  document.getElementById('h-checkin-time').value || null,
      checkOutDate: document.getElementById('h-checkout-date').value || null,
      checkOutTime: document.getElementById('h-checkout-time').value || null,
      confirmation: document.getElementById('h-confirm').value.trim() || null,
      notes:        document.getElementById('h-notes').value.trim() || null,
    };
    if (trip.hotel.name && JSON.stringify(trip.hotel) !== prev) suggestSection = 'hotel';
  } else if (section === 'transport') {
    trip.transport = {
      gettingThere:      document.getElementById('t-there').value.trim() || null,
      gettingThereNotes: document.getElementById('t-there-notes').value.trim() || null,
      gettingBack:       document.getElementById('t-back').value.trim() || null,
      gettingBackNotes:  document.getElementById('t-back-notes').value.trim() || null,
    };
  }

  saveTrip(trip);
  editingSection = null;
  renderHeader();
  renderItinerary();
  renderInfo();
  window.showToast?.('Saved');

  if (suggestSection) setTimeout(() => offerItineraryEvents(suggestSection), 400);
}

// ── Itinerary Event Suggestions ───────────────────────────────────────────────

function buildItinerarySuggestions(section) {
  const suggestions = [];
  const firstDay = trip.days?.[0];
  const lastDay  = trip.days?.[trip.days.length - 1];

  if (section === 'flight') {
    const fo = trip.flightOut ?? {};
    if (fo.airline || fo.flightNumber) {
      const label = fo.flightNumber ?? fo.airline ?? 'Outbound Flight';
      const route = trip.departFrom && trip.destination ? ` · ${trip.departFrom} → ${trip.destination}` : '';
      suggestions.push({
        title: `${label}${route}`,
        dayId: firstDay?.id ?? null, dayLabel: firstDay?.label ?? 'Day 1',
        time: fo.departTime ?? null,
        notes: fo.confirmation ? `Conf: ${fo.confirmation}` : '',
      });
    }
    const fr = trip.flightReturn ?? {};
    if (fr.airline || fr.flightNumber) {
      const label = fr.flightNumber ?? fr.airline ?? 'Return Flight';
      const route = trip.destination && trip.departFrom ? ` · ${trip.destination} → ${trip.departFrom}` : '';
      suggestions.push({
        title: `${label}${route}`,
        dayId: lastDay?.id ?? null, dayLabel: lastDay?.label ?? 'Last Day',
        time: fr.departTime ?? null,
        notes: fr.confirmation ? `Conf: ${fr.confirmation}` : '',
      });
    }
  }

  if (section === 'hotel') {
    const h = trip.hotel ?? {};
    if (h.name) {
      const ciDay = h.checkInDate ? (trip.days?.find(d => d.date === h.checkInDate) ?? firstDay) : firstDay;
      const coDay = h.checkOutDate ? (trip.days?.find(d => d.date === h.checkOutDate) ?? lastDay) : lastDay;
      suggestions.push({
        title: `Hotel Check-in: ${h.name}`,
        dayId: ciDay?.id ?? null, dayLabel: ciDay?.label ?? '',
        time: h.checkInTime ?? null, notes: h.confirmation ? `Conf: ${h.confirmation}` : '',
      });
      suggestions.push({
        title: `Hotel Check-out: ${h.name}`,
        dayId: coDay?.id ?? null, dayLabel: coDay?.label ?? '',
        time: h.checkOutTime ?? null, notes: '',
      });
    }
  }

  return suggestions;
}

function offerItineraryEvents(section) {
  const suggestions = buildItinerarySuggestions(section);
  if (suggestions.length === 0) return;

  document.getElementById('suggest-events-list').innerHTML = suggestions.map((s, i) => `
    <label class="flex items-start gap-2.5 cursor-pointer p-2 rounded-lg hover:bg-gray-50">
      <input type="checkbox" class="suggest-ev-check mt-0.5 text-indigo-600 rounded" data-idx="${i}" checked />
      <div>
        <p class="text-sm font-medium text-gray-800">${esc(s.title)}</p>
        <p class="text-xs text-gray-500">${esc(s.dayLabel)}${s.time ? ' · ' + s.time : ''}</p>
      </div>
    </label>`).join('');

  openModal('modal-suggest-events');

  document.getElementById('suggest-events-skip').onclick = () => closeModal('modal-suggest-events');
  document.getElementById('suggest-events-add').onclick = () => {
    const checks = document.querySelectorAll('.suggest-ev-check:checked');
    if (!trip.itineraryEvents) trip.itineraryEvents = [];
    checks.forEach(cb => {
      const s = suggestions[parseInt(cb.dataset.idx)];
      trip.itineraryEvents.push({ id: genId(), tripId, dayId: s.dayId, time: s.time, title: s.title, notes: s.notes ?? '' });
    });
    saveTrip(trip);
    closeModal('modal-suggest-events');
    renderItinerary();
    if (checks.length > 0) window.showToast?.(`${checks.length} event${checks.length > 1 ? 's' : ''} added to itinerary`);
  };
}

// ── Init ──────────────────────────────────────────────────────────────────────

renderHeader();
renderPackingList();
renderItinerary();
renderInfo();
</script>
