---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Trip" page="trip">

  <!-- Header -->
  <header class="sticky top-0 z-30 bg-white border-b border-gray-100 shadow-sm">
    <div class="flex items-center gap-3 px-4 py-3 max-w-lg mx-auto">
      <a id="back-btn" href="#" class="text-gray-500 hover:text-gray-700 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </a>
      <div class="flex-1 min-w-0">
        <h1 id="trip-title" class="font-bold text-gray-900 truncate">Loading…</h1>
        <p id="trip-subtitle" class="text-xs text-gray-500 truncate"></p>
      </div>
      <div id="trip-actions" class="flex items-center gap-1"></div>
    </div>

    <!-- Tabs -->
    <div class="flex border-t border-gray-100 max-w-lg mx-auto">
      <button class="tab-btn active" style="font-size:0.75rem" data-tab="packing">Packing</button>
      <button class="tab-btn" style="font-size:0.75rem" data-tab="itinerary">Itinerary</button>
      <button class="tab-btn" style="font-size:0.75rem" data-tab="info">Info</button>
      <button class="tab-btn" style="font-size:0.75rem" data-tab="expenses">Expenses</button>
    </div>
  </header>

  <!-- Tab panels -->
  <main class="max-w-lg mx-auto">
    <div id="tab-packing"   class="tab-panel"></div>
    <div id="tab-itinerary" class="tab-panel hidden"></div>
    <div id="tab-info"      class="tab-panel hidden px-4 py-4 space-y-4"></div>
    <div id="tab-expenses"  class="tab-panel hidden"></div>
  </main>

  <!-- ── Add / Edit Item Modal ── -->
  <div id="modal-item" class="modal-overlay hidden">
    <div class="modal-box">
      <div class="flex items-center justify-between p-4 border-b">
        <h2 id="modal-item-title" class="text-lg font-bold">Add Item</h2>
        <button class="close-modal text-gray-400 hover:text-gray-600 text-2xl leading-none"
                data-modal="modal-item">&times;</button>
      </div>
      <form id="form-item" class="p-4 space-y-3">
        <input type="hidden" id="item-edit-id" />
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Item *</label>
          <input id="item-text" type="text" class="input" placeholder="e.g. Sunscreen" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
          <select id="item-category" class="input"><option value="">— None —</option></select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Priority</label>
          <select id="item-priority" class="input"><option value="">— None —</option></select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Quantity</label>
          <input id="item-qty" type="number" min="1" class="input" placeholder="Leave blank if N/A" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Needed on Day <span class="text-gray-400 font-normal text-xs">(optional, info only)</span>
          </label>
          <input id="item-needed-day" type="text" class="input" placeholder="e.g. Day 1, Day 3 – Hotel check-in" />
        </div>
        <div class="flex gap-3 pt-1">
          <button type="button" class="close-modal btn-secondary flex-1" data-modal="modal-item">Cancel</button>
          <button type="submit" class="btn-primary flex-1">Save</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Add / Edit Event Modal ── -->
  <div id="modal-event" class="modal-overlay hidden">
    <div class="modal-box">
      <div class="flex items-center justify-between p-4 border-b">
        <h2 id="modal-event-title" class="text-lg font-bold">Add Event</h2>
        <button class="close-modal text-gray-400 hover:text-gray-600 text-2xl leading-none"
                data-modal="modal-event">&times;</button>
      </div>
      <form id="form-event" class="p-4 space-y-3">
        <input type="hidden" id="event-edit-id" />
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Event Title *</label>
          <input id="event-title" type="text" class="input" placeholder="e.g. Flight check-in" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Day</label>
          <select id="event-day" class="input"></select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Time</label>
          <input id="event-time" type="time" class="input" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
          <textarea id="event-notes" class="input resize-none" rows="2" placeholder="Optional details"></textarea>
        </div>
        <div class="flex gap-3 pt-1">
          <button type="button" class="close-modal btn-secondary flex-1" data-modal="modal-event">Cancel</button>
          <button type="submit" class="btn-primary flex-1">Save</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Suggest Itinerary Events Modal ── -->
  <div id="modal-suggest-events" class="modal-overlay hidden">
    <div class="modal-box max-w-sm">
      <div class="flex items-center justify-between p-4 border-b">
        <h2 class="text-lg font-bold">Add to Itinerary?</h2>
        <button class="close-modal text-gray-400 hover:text-gray-600 text-2xl leading-none"
                data-modal="modal-suggest-events">&times;</button>
      </div>
      <div class="p-4">
        <p class="text-sm text-gray-600 mb-3">Based on your info, add these events to your itinerary?</p>
        <div id="suggest-events-list" class="space-y-2.5 mb-4"></div>
        <div class="flex gap-3">
          <button id="suggest-events-skip" class="btn-secondary flex-1">Skip</button>
          <button id="suggest-events-add" class="btn-primary flex-1">Add Selected</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Add / Edit Expense Modal ── -->
  <div id="modal-expense" class="modal-overlay hidden">
    <div class="modal-box">
      <div class="flex items-center justify-between p-4 border-b flex-shrink-0">
        <h2 id="modal-expense-title" class="text-lg font-bold">Add Expense</h2>
        <button class="close-modal text-gray-400 hover:text-gray-600 text-2xl leading-none"
                data-modal="modal-expense">&times;</button>
      </div>
      <div class="overflow-y-auto" style="max-height:calc(100vh - 160px)">
        <form id="form-expense" class="p-4 space-y-3">
          <input type="hidden" id="expense-edit-id" />
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Description *</label>
            <input id="exp-description" type="text" class="input" placeholder="e.g. Dinner at Joe's" required />
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Amount *</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none">$</span>
                <input id="exp-amount" type="number" min="0" step="0.01" class="input pl-6"
                       placeholder="0.00" required />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Date</label>
              <input id="exp-date" type="date" class="input" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
              <select id="exp-category" class="input">
                <option value="food">Food &amp; Drink</option>
                <option value="transport">Transport</option>
                <option value="accommodation">Accommodation</option>
                <option value="entertainment">Entertainment</option>
                <option value="shopping">Shopping</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Paid by *</label>
              <select id="exp-paid-by" class="input"></select>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Venue / Note <span class="text-xs text-gray-400 font-normal">(optional)</span>
            </label>
            <input id="exp-venue" type="text" class="input" placeholder="e.g. Restaurant name, receipt note" />
          </div>
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label class="text-sm font-medium text-gray-700">Split between</label>
              <button type="button" id="exp-select-all"
                      class="text-xs text-indigo-600 hover:text-indigo-800 font-medium">Select All</button>
            </div>
            <div id="exp-split-list" class="border border-gray-200 rounded-lg p-2.5 space-y-0.5"></div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label class="text-sm font-medium text-gray-700">Split method</label>
              <span id="exp-per-person" class="text-xs text-indigo-600 font-medium"></span>
            </div>
            <div class="flex gap-2">
              <button type="button" id="exp-split-equal" class="btn-primary flex-1 text-sm py-1.5">Equal</button>
              <button type="button" id="exp-split-custom" class="btn-secondary flex-1 text-sm py-1.5">Custom</button>
            </div>
          </div>
          <!-- Custom amounts (shown when method = custom) -->
          <div id="exp-custom-amounts" class="hidden border border-gray-200 rounded-lg p-3 space-y-2.5 bg-gray-50">
            <div id="exp-custom-list" class="space-y-2"></div>
            <div class="flex justify-between items-center pt-1.5 border-t border-gray-200 text-sm">
              <span id="exp-remaining-label" class="text-gray-500 text-xs">remaining</span>
              <span id="exp-remaining" class="font-semibold text-amber-600 text-sm">$0.00</span>
            </div>
          </div>
          <div class="flex gap-3 pt-1">
            <button type="button" class="close-modal btn-secondary flex-1" data-modal="modal-expense">Cancel</button>
            <button type="submit" class="btn-primary flex-1">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- ── Settle Up Modal ── -->
  <div id="modal-settle" class="modal-overlay hidden">
    <div class="modal-box">
      <div class="flex items-center justify-between p-4 border-b">
        <h2 class="text-lg font-bold">Settle Up</h2>
        <button class="close-modal text-gray-400 hover:text-gray-600 text-2xl leading-none"
                data-modal="modal-settle">&times;</button>
      </div>
      <div id="settle-content" class="p-4 overflow-y-auto" style="max-height:calc(100vh - 120px)"></div>
    </div>
  </div>

  <!-- ── Add Member Modal ── -->
  <div id="modal-member" class="modal-overlay hidden">
    <div class="modal-box max-w-sm">
      <div class="flex items-center justify-between p-4 border-b">
        <h2 class="text-lg font-bold">Add Member</h2>
        <button class="close-modal text-gray-400 hover:text-gray-600 text-2xl leading-none"
                data-modal="modal-member">&times;</button>
      </div>
      <div class="p-4 space-y-4">
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">From My People</p>
          <div id="member-import-list" class="flex flex-wrap gap-2 min-h-[1rem]"></div>
          <p id="member-import-empty" class="text-xs text-gray-400 italic hidden">All saved people are already in this trip.</p>
        </div>
        <div class="border-t border-gray-100 pt-3">
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Add New</p>
          <form id="form-member-new" class="space-y-2">
            <input id="member-new-name" type="text" class="input" placeholder="Name" />
            <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer select-none">
              <input type="checkbox" id="member-save-global" class="h-4 w-4 rounded text-indigo-600" />
              Save to My People list
            </label>
            <button type="submit" class="btn-primary w-full text-sm py-2">Add to Trip</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Confirm Modal ── -->
  <div id="modal-confirm" class="modal-overlay hidden">
    <div class="modal-box max-w-sm">
      <div class="p-6 text-center">
        <div class="text-4xl mb-3" id="confirm-icon">⚠️</div>
        <h3 id="confirm-title" class="text-lg font-bold mb-2">Are you sure?</h3>
        <p id="confirm-msg" class="text-sm text-gray-600 mb-6"></p>
        <div class="flex gap-3">
          <button id="confirm-cancel" class="btn-secondary flex-1">Cancel</button>
          <button id="confirm-ok" class="btn-danger flex-1">Confirm</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Add / Edit Destination Modal ── -->
  <div id="modal-destination" class="modal-overlay hidden">
    <div class="modal-box">
      <div class="flex items-center justify-between p-4 border-b flex-shrink-0">
        <h2 id="modal-dest-title" class="text-lg font-bold">Add Destination</h2>
        <button class="close-modal text-gray-400 hover:text-gray-600 text-2xl leading-none"
                data-modal="modal-destination">&times;</button>
      </div>
      <div class="overflow-y-auto" style="max-height:calc(100vh - 160px)">
        <form id="form-destination" class="p-4 space-y-3">
          <input type="hidden" id="dest-edit-id" />
          <div>
            <label class="block text-xs text-gray-500 mb-1">Country *</label>
            <div class="relative overflow-visible">
              <input id="dest-country" type="text" class="input text-sm w-full" placeholder="Start typing country name..." required autocomplete="off" />
              <ul id="dest-dropdown" class="fixed z-[9999] w-72 bg-white border border-gray-200 rounded-lg shadow-lg hidden max-h-48 overflow-y-auto"></ul>
                <!-- Country options populated by JavaScript -->
              </ul>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-xs text-gray-500 mb-1">City</label>
              <input id="dest-city" type="text" class="input text-sm" placeholder="e.g. Seoul" />
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Region</label>
              <input id="dest-region" type="text" class="input text-sm" placeholder="e.g. Seoul, NSW, CA" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-xs text-gray-500 mb-1">Arrival Date</label>
              <input id="dest-arrival" type="date" class="input text-sm" />
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Departure Date</label>
              <input id="dest-departure" type="date" class="input text-sm" />
            </div>
          </div>
          <div id="dest-country-info" class="hidden bg-blue-50 rounded-lg p-3 space-y-1.5 text-sm">
            <div class="flex justify-between items-center">
              <span class="text-gray-500 text-xs">Currency</span>
              <span id="dest-info-currency" class="font-medium text-gray-800 text-xs"></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-500 text-xs">Plug Types</span>
              <span id="dest-info-plugs" class="font-medium text-gray-800 text-xs"></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-500 text-xs">Voltage</span>
              <span id="dest-info-voltage" class="font-medium text-gray-800 text-xs"></span>
            </div>
            <div id="dest-voltage-warn" class="hidden text-xs text-amber-800 bg-amber-50 border border-amber-200 p-2 rounded-lg mt-1">
              ⚡ 220V destination — check your devices are dual-voltage (100–240V label). Most modern electronics are fine; hair dryers and curling irons often are not.
            </div>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Exchange Rate Note</label>
            <input id="dest-currency-notes" type="text" class="input text-sm"
                   placeholder="e.g. 1 USD ≈ 1,350 KRW as of May 2026" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">ATM / Cash Notes</label>
            <input id="dest-atm-notes" type="text" class="input text-sm"
                   placeholder="e.g. Use 7-Eleven ATMs, avoid airport exchange" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Card Acceptance</label>
            <input id="dest-card-notes" type="text" class="input text-sm"
                   placeholder="e.g. Visa widely accepted; carry cash for street food" />
          </div>
          <div class="flex gap-3 pt-1">
            <button type="button" class="close-modal btn-secondary flex-1" data-modal="modal-destination">Cancel</button>
            <button type="submit" class="btn-primary flex-1">Save Destination</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- ── International Packing Suggestions Modal ── -->
  <div id="modal-intl-suggest" class="modal-overlay hidden">
    <div class="modal-box max-w-sm">
      <div class="flex items-center justify-between p-4 border-b">
        <h2 class="text-lg font-bold">International Packing</h2>
        <button class="close-modal text-gray-400 hover:text-gray-600 text-2xl leading-none"
                data-modal="modal-intl-suggest">&times;</button>
      </div>
      <div class="p-4">
        <p class="text-sm text-gray-600 mb-3">Add these international travel items to your packing list?</p>
        <div id="intl-suggest-list" class="space-y-2 mb-4 max-h-64 overflow-y-auto"></div>
        <div class="flex gap-3">
          <button id="intl-suggest-skip" class="btn-secondary flex-1">Skip</button>
          <button id="intl-suggest-add" class="btn-primary flex-1">Add Selected</button>
        </div>
      </div>
    </div>
  </div>

</Layout>

<script>
import {
  genId, getTrip, saveTrip, deleteTrip, archiveTrip, unarchiveTrip, exportTrip,
  getProfile, saveProfile, duplicateTrip,
} from '../scripts/store.js';
import {
  getAllCategories, getAllPriorities, getCategoryColor, getPriorityColor,
  getCategoryLabel, getPriorityLabel, migrateChecklistItems,
  calcClothing, formatDate, formatDateRange, buildDays, TEMPLATES,
} from '../scripts/templates.js';
import {
  COUNTRIES, getCountry, getNeededPlugTypes, needs220VWarning, hasInternationalDests, PLUG_DESCRIPTIONS,
} from '../data/countries.js';
import { initCountryAutocomplete, getSelectedCountry, setSelectedCountry, clearAutocomplete } from '../scripts/autocomplete.js';

const BASE = import.meta.env.BASE_URL;
const params = new URLSearchParams(window.location.search);
const tripId = params.get('id');

if (!tripId) { location.replace(BASE); throw 0; }
let trip = getTrip(tripId);
if (!trip) { location.replace(BASE); throw 0; }

function migrateTrip(t) {
  let changed = false;
  if (!t.destinations) {
    t.destinations = t.destination ? [{
      id: genId(), city: t.destination, country: '', countryCode: '',
      arrivalDate: t.startDate ?? '', departureDate: t.endDate ?? '',
      currency: '', currencyCode: '', plugTypes: [], voltage: '',
      currencyNotes: '', atmNotes: '', cardNotes: '',
    }] : [];
    changed = true;
  }
  if (!t.origin) { t.origin = { city: t.departFrom ?? '', country: 'USA' }; changed = true; }
  if (!t.travelDocuments) {
    t.travelDocuments = {
      passport: { name: '', expiryDate: '' },
      insurance: { hasInsurance: false, provider: '', policyNumber: '', notes: '' },
      customReminders: [], dismissedVisaReminders: [],
    };
    changed = true;
  }
  if (!t.travelDocuments.dismissedVisaReminders) { t.travelDocuments.dismissedVisaReminders = []; changed = true; }
  if (!t.laundryPlan) { t.laundryPlan = { enabled: false, everyXDays: 7 }; changed = true; }
  if (!t.dismissedIntlSuggestions) { t.dismissedIntlSuggestions = []; changed = true; }
  return changed;
}

const tripMigrated = migrateTrip(trip);
const checklistMigrated = migrateChecklistItems(trip.checklistItems ?? []);
if (tripMigrated || checklistMigrated) saveTrip(trip);

let profile = getProfile();
const readonly = trip.status === 'archived';

// filter / ui state
let activeCategory = null;
let activePriority = null;
let editingSection = null;
let expCategoryFilter = null;
let expPersonFilter = null;
let expSplitMethod = 'equal';

// ── Helpers ──────────────────────────────────────────────────────────────────

function esc(s) {
  const d = document.createElement('div');
  d.textContent = String(s ?? '');
  return d.innerHTML;
}

function fmt(n) { return `$${(+n || 0).toFixed(2)}`; }

function reload() {
  trip = getTrip(tripId);
  profile = getProfile();
  renderHeader();
  renderPackingList();
  renderItinerary();
  renderInfo();
  renderExpenses();
}

// ── Tabs ─────────────────────────────────────────────────────────────────────

const tabBtns = document.querySelectorAll('.tab-btn[data-tab]');
const tabPanels = document.querySelectorAll('.tab-panel');
let currentTab = 'packing';

tabBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    if (btn.dataset.tab !== 'packing')  { activeCategory = null; activePriority = null; }
    if (btn.dataset.tab !== 'expenses') { expCategoryFilter = null; expPersonFilter = null; }
    currentTab = btn.dataset.tab;
    tabBtns.forEach(b => b.classList.toggle('active', b.dataset.tab === currentTab));
    tabPanels.forEach(p => p.classList.toggle('hidden', p.id !== `tab-${currentTab}`));
  });
});

// ── Modals ───────────────────────────────────────────────────────────────────

function openModal(id) { document.getElementById(id)?.classList.remove('hidden'); }
function closeModal(id) { document.getElementById(id)?.classList.add('hidden'); }

document.querySelectorAll('.close-modal').forEach(btn => {
  btn.addEventListener('click', () => closeModal(btn.dataset.modal));
});
document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(overlay.id); });
});
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    ['modal-item','modal-event','modal-confirm','modal-suggest-events',
     'modal-expense','modal-settle','modal-member','modal-destination','modal-intl-suggest'].forEach(closeModal);
  }
});

function confirmAction(icon, title, msg, okLabel, okClass, onOk) {
  document.getElementById('confirm-icon').textContent = icon;
  document.getElementById('confirm-title').textContent = title;
  document.getElementById('confirm-msg').textContent = msg;
  const okBtn = document.getElementById('confirm-ok');
  okBtn.textContent = okLabel;
  okBtn.className = okClass + ' flex-1';
  openModal('modal-confirm');
  const handler = () => { closeModal('modal-confirm'); onOk(); okBtn.removeEventListener('click', handler); };
  okBtn.addEventListener('click', handler);
  document.getElementById('confirm-cancel').onclick = () => { closeModal('modal-confirm'); okBtn.removeEventListener('click', handler); };
}

// ── Header ───────────────────────────────────────────────────────────────────

function renderHeader() {
  document.getElementById('back-btn').href = BASE;
  document.getElementById('trip-title').textContent = trip.name;
  const dests = trip.destinations ?? [];
  const destLabel = dests.length === 0
    ? (trip.destination ?? '')
    : dests.map(d => d.city || d.country).filter(Boolean).join(' → ');
  const originLabel = (trip.origin?.city || trip.departFrom) ? ` · from ${trip.origin?.city || trip.departFrom}` : '';
  document.getElementById('trip-subtitle').textContent =
    `${destLabel}${originLabel} · ${formatDateRange(trip.startDate, trip.endDate)}`;

  const actions = document.getElementById('trip-actions');
  if (readonly) {
    actions.innerHTML = `<span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded-full font-medium">Archived</span>`;
    return;
  }
  actions.innerHTML = `
    <button id="btn-export-trip" class="btn-ghost p-1.5" title="Export JSON">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
      </svg>
    </button>
    <button id="btn-archive-trip" class="btn-ghost p-1.5" title="Archive Trip">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
      </svg>
    </button>`;
  document.getElementById('btn-export-trip').addEventListener('click', () => exportTrip(trip));
  document.getElementById('btn-archive-trip').addEventListener('click', () => {
    confirmAction('📦', 'Archive this trip?', 'The trip will be frozen as a read-only snapshot in the Archive.',
      'Archive', 'btn-secondary',
      () => { archiveTrip(tripId); window.showToast?.('Trip archived'); setTimeout(() => location.replace(`${BASE}archive/`), 600); });
  });
}

// ── Packing List ─────────────────────────────────────────────────────────────

function buildFilterBar(items) {
  const allCats = getAllCategories(profile.customCategories);
  const allPris = getAllPriorities(profile.customPriorities);
  const catCounts = {}, priCounts = {};
  items.forEach(item => {
    if (item.category) catCounts[item.category] = (catCounts[item.category] ?? 0) + 1;
    if (item.priority) priCounts[item.priority] = (priCounts[item.priority] ?? 0) + 1;
  });
  const catIds = Object.keys(catCounts), priIds = Object.keys(priCounts);
  if (!catIds.length && !priIds.length) return '';

  const catBtn = id => {
    const tag = allCats.find(c => c.id === id); if (!tag) return '';
    const cls = activeCategory === id ? tag.color + ' ring-1 ring-inset ring-current' : 'bg-gray-100 text-gray-600';
    return `<button class="filter-cat text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0 ${cls}" data-cat="${esc(id)}">${esc(tag.label)} <span class="font-normal">${catCounts[id]}</span></button>`;
  };
  const priBtn = id => {
    const tag = allPris.find(p => p.id === id); if (!tag) return '';
    const cls = activePriority === id ? tag.color + ' ring-1 ring-inset ring-current' : 'bg-gray-100 text-gray-600';
    return `<button class="filter-pri text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0 ${cls}" data-pri="${esc(id)}">${esc(tag.label)} <span class="font-normal">${priCounts[id]}</span></button>`;
  };
  const hasFilter = activeCategory !== null || activePriority !== null;
  const filteredCount = items.filter(i => (activeCategory === null || i.category === activeCategory) && (activePriority === null || i.priority === activePriority)).length;

  return `<div class="px-4 pb-2 space-y-1.5">
    ${catIds.length ? `<div class="flex gap-1.5 overflow-x-auto pb-0.5" style="scrollbar-width:none;-webkit-overflow-scrolling:touch">
      <button class="filter-cat text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0 ${activeCategory === null ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600'}" data-cat="">All</button>
      ${catIds.map(catBtn).join('')}</div>` : ''}
    ${priIds.length ? `<div class="flex gap-1.5 overflow-x-auto pb-0.5" style="scrollbar-width:none;-webkit-overflow-scrolling:touch">
      <button class="filter-pri text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0 ${activePriority === null ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600'}" data-pri="">All</button>
      ${priIds.map(priBtn).join('')}</div>` : ''}
    ${hasFilter ? `<p class="text-xs text-indigo-600 font-medium">${filteredCount} item${filteredCount !== 1 ? 's' : ''} shown</p>` : ''}
  </div>`;
}

function renderPackingList() {
  const panel = document.getElementById('tab-packing');
  const items = trip.checklistItems ?? [];
  const total = items.length, checked = items.filter(i => i.checked).length;
  const pct = total === 0 ? 0 : Math.round((checked / total) * 100);
  const visibleItems = items.filter(item =>
    (activeCategory === null || item.category === activeCategory) &&
    (activePriority === null || item.priority === activePriority));

  const laundry = trip.laundryPlan ?? { enabled: false, everyXDays: 7 };
  const profile = getProfile();
  const homeCountryCode = profile.homeBase?.countryCode || 'US';
  const hasIntl = hasInternationalDests(trip.destinations ?? [], homeCountryCode);
  const dismissed = trip.dismissedIntlSuggestions ?? [];
  const pendingIntlSuggestions = hasIntl && buildIntlSuggestions().some(s => !dismissed.includes(s.key));

  panel.innerHTML = `
    <div class="sticky top-[97px] bg-white border-b border-gray-100 z-20">
      <div class="px-4 py-2 flex items-center justify-between gap-4">
        <div class="flex-1">
          <div class="flex justify-between text-xs text-gray-500 mb-1"><span>${checked}/${total} packed</span><span>${pct}%</span></div>
          <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
            <div class="h-full bg-indigo-500 rounded-full transition-all duration-300" style="width:${pct}%"></div>
          </div>
        </div>
        ${!readonly ? `<button id="btn-add-item-top" class="btn-primary text-xs py-1.5 px-3 flex-shrink-0">+ Add Item</button>` : ''}
      </div>
      ${total > 0 ? buildFilterBar(items) : ''}
    </div>
    ${pendingIntlSuggestions ? `<div class="mx-4 mt-3 p-3 bg-blue-50 border border-blue-200 rounded-lg flex items-start justify-between gap-3">
      <div><p class="text-sm font-semibold text-blue-800">International trip detected</p>
        <p class="text-xs text-blue-600 mt-0.5">You have items to add for international travel.</p></div>
      <button id="btn-intl-suggest" class="btn-primary text-xs py-1.5 px-3 flex-shrink-0">Review</button>
    </div>` : ''}
    ${!readonly ? `<div class="mx-4 mt-3 p-3 bg-gray-50 rounded-lg border border-gray-200">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-700">Doing laundry during trip?</p>
          ${laundry.enabled ? `<p class="text-xs text-gray-500 mt-0.5">Clothing quantities reduced for laundry every ${laundry.everyXDays} days</p>` : ''}
        </div>
        <label class="relative inline-flex items-center cursor-pointer flex-shrink-0">
          <input type="checkbox" id="laundry-toggle" class="sr-only peer" ${laundry.enabled ? 'checked' : ''} />
          <div class="w-10 h-5 bg-gray-200 peer-focus:ring-2 peer-focus:ring-indigo-300 rounded-full peer peer-checked:bg-indigo-600 after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5"></div>
        </label>
      </div>
      ${laundry.enabled ? `<div class="flex items-center gap-3 mt-2">
        <span class="text-xs text-gray-500">Every</span>
        ${[3, 5, 7].map(d => `<button class="laundry-days text-xs px-3 py-1 rounded-full font-medium ${laundry.everyXDays === d ? 'bg-indigo-600 text-white' : 'bg-gray-200 text-gray-700'}" data-days="${d}">${d} days</button>`).join('')}
      </div>` : ''}
    </div>` : ''}
    <ul>
      ${visibleItems.map(item => renderItemRow(item)).join('')}
      ${visibleItems.length === 0 && total > 0 ? `<li class="px-4 py-10 text-center text-sm text-gray-400 italic">No items match the active filter</li>` : ''}
      ${total === 0 ? `<li class="px-4 py-12 text-center text-sm text-gray-400">No items yet — tap + Add Item to get started.</li>` : ''}
    </ul>`;

  panel.querySelector('#btn-add-item-top')?.addEventListener('click', () => openItemModal());
  panel.querySelectorAll('[data-toggle]').forEach(cb => cb.addEventListener('change', () => toggleItem(cb.dataset.toggle)));
  panel.querySelectorAll('[data-edit-item]').forEach(btn => btn.addEventListener('click', () => openItemModal(btn.dataset.editItem)));
  panel.querySelectorAll('[data-del-item]').forEach(btn => btn.addEventListener('click', () => deleteItem(btn.dataset.delItem)));
  panel.querySelectorAll('.filter-cat').forEach(btn => btn.addEventListener('click', () => { activeCategory = btn.dataset.cat || null; renderPackingList(); }));
  panel.querySelectorAll('.filter-pri').forEach(btn => btn.addEventListener('click', () => { activePriority = btn.dataset.pri || null; renderPackingList(); }));
  panel.querySelectorAll('[data-clothing-dec]').forEach(btn => btn.addEventListener('click', () => adjustClothingQty(btn.dataset.clothingDec, -1)));
  panel.querySelectorAll('[data-clothing-inc]').forEach(btn => btn.addEventListener('click', () => adjustClothingQty(btn.dataset.clothingInc, 1)));

  panel.querySelector('#btn-intl-suggest')?.addEventListener('click', () => openIntlSuggestModal());

  panel.querySelector('#laundry-toggle')?.addEventListener('change', e => {
    if (!trip.laundryPlan) trip.laundryPlan = { enabled: false, everyXDays: 7 };
    trip.laundryPlan.enabled = e.target.checked;
    applyLaundryToClothing();
    saveTrip(trip); renderPackingList();
  });
  panel.querySelectorAll('.laundry-days').forEach(btn => btn.addEventListener('click', () => {
    if (!trip.laundryPlan) trip.laundryPlan = { enabled: true, everyXDays: 7 };
    trip.laundryPlan.everyXDays = parseInt(btn.dataset.days);
    applyLaundryToClothing();
    saveTrip(trip); renderPackingList();
  }));
}

function renderItemRow(item) {
  const catTag = item.category ? `<span class="badge ${getCategoryColor(item.category, profile.customCategories)} ml-1">${esc(getCategoryLabel(item.category, profile.customCategories))}</span>` : '';
  const priTag = item.priority ? `<span class="badge ${getPriorityColor(item.priority, profile.customPriorities)} ml-1">${esc(getPriorityLabel(item.priority, profile.customPriorities))}</span>` : '';
  const neededDay = item.neededOnDay ? `<span class="text-xs text-gray-400 block mt-0.5">📅 ${esc(item.neededOnDay)}</span>` : '';
  const qtyBlock = item.isClothing
    ? `<div class="flex items-center gap-1 flex-shrink-0 ml-1">
        ${!readonly ? `<button data-clothing-dec="${esc(item.id)}" class="w-6 h-6 rounded-full bg-gray-100 hover:bg-orange-100 text-gray-600 hover:text-orange-700 text-sm font-bold flex items-center justify-center transition-colors leading-none">−</button>` : ''}
        <span class="text-sm font-semibold text-orange-700 min-w-[1.25rem] text-center">${item.quantity ?? 0}</span>
        ${!readonly ? `<button data-clothing-inc="${esc(item.id)}" class="w-6 h-6 rounded-full bg-gray-100 hover:bg-orange-100 text-gray-600 hover:text-orange-700 text-sm font-bold flex items-center justify-center transition-colors leading-none">+</button>` : ''}
      </div>`
    : (item.quantity != null ? `<span class="text-xs text-gray-400 ml-1 flex-shrink-0">×${item.quantity}</span>` : '');
  const editBtn = !readonly ? `
    <button data-edit-item="${esc(item.id)}" class="opacity-0 group-hover:opacity-100 text-gray-300 hover:text-indigo-500 transition-all p-0.5" title="Edit">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
    </button>
    <button data-del-item="${esc(item.id)}" class="opacity-0 group-hover:opacity-100 text-gray-300 hover:text-red-400 transition-all p-0.5 text-base leading-none" title="Delete">×</button>` : '';

  return `
    <li class="group flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 border-b border-gray-50 transition-colors ${item.checked ? 'opacity-60' : ''}">
      ${!readonly ? `<input type="checkbox" ${item.checked ? 'checked' : ''} data-toggle="${esc(item.id)}" class="h-4 w-4 rounded text-indigo-600 cursor-pointer flex-shrink-0">` : `
      <div class="w-4 h-4 rounded border-2 ${item.checked ? 'bg-indigo-600 border-indigo-600' : 'border-gray-300'} flex-shrink-0 flex items-center justify-center">
        ${item.checked ? `<svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>` : ''}
      </div>`}
      <div class="flex-1 min-w-0">
        <div class="flex items-center flex-wrap gap-x-0.5">
          <span class="text-sm ${item.checked ? 'line-through text-gray-400' : 'text-gray-800'}">${esc(item.text)}</span>
          ${!item.isClothing ? qtyBlock : ''}${catTag}${priTag}
        </div>
        ${neededDay}
      </div>
      ${item.isClothing ? qtyBlock : ''}
      <div class="flex items-center gap-0.5">${editBtn}</div>
    </li>`;
}

function adjustClothingQty(itemId, delta) {
  const item = trip.checklistItems.find(i => i.id === itemId);
  if (!item?.isClothing) return;
  item.quantity = Math.max(0, (item.quantity ?? 0) + delta);
  if (!trip.clothingOverrides) trip.clothingOverrides = {};
  trip.clothingOverrides[item.clothingType] = item.quantity;
  saveTrip(trip); renderPackingList();
}

function toggleItem(itemId) {
  const item = trip.checklistItems.find(i => i.id === itemId);
  if (!item) return;
  item.checked = !item.checked;
  saveTrip(trip); renderPackingList();
}

function deleteItem(itemId) {
  trip.checklistItems = trip.checklistItems.filter(i => i.id !== itemId);
  saveTrip(trip); renderPackingList(); window.showToast?.('Item removed');
}

// ── Item Modal ───────────────────────────────────────────────────────────────

function populateTagSelects(selectedCategory = null, selectedPriority = null) {
  document.getElementById('item-category').innerHTML =
    `<option value="">— None —</option>` +
    getAllCategories(profile.customCategories).map(c => `<option value="${esc(c.id)}" ${c.id === selectedCategory ? 'selected' : ''}>${esc(c.label)}</option>`).join('');
  document.getElementById('item-priority').innerHTML =
    `<option value="">— None —</option>` +
    getAllPriorities(profile.customPriorities).map(p => `<option value="${esc(p.id)}" ${p.id === selectedPriority ? 'selected' : ''}>${esc(p.label)}</option>`).join('');
}

function openItemModal(editItemId = null) {
  document.getElementById('form-item').reset();
  document.getElementById('item-edit-id').value = '';
  document.getElementById('modal-item-title').textContent = editItemId ? 'Edit Item' : 'Add Item';
  if (editItemId) {
    const item = trip.checklistItems.find(i => i.id === editItemId);
    if (item) {
      document.getElementById('item-edit-id').value = item.id;
      document.getElementById('item-text').value = item.text;
      document.getElementById('item-qty').value = item.quantity ?? '';
      document.getElementById('item-needed-day').value = item.neededOnDay ?? '';
      populateTagSelects(item.category, item.priority);
    }
  } else { populateTagSelects(); }
  openModal('modal-item');
  setTimeout(() => document.getElementById('item-text').focus(), 50);
}

document.getElementById('form-item').addEventListener('submit', e => {
  e.preventDefault();
  const editId = document.getElementById('item-edit-id').value;
  const text = document.getElementById('item-text').value.trim();
  const category = document.getElementById('item-category').value || null;
  const priority = document.getElementById('item-priority').value || null;
  const qtyVal = document.getElementById('item-qty').value;
  const quantity = qtyVal ? parseInt(qtyVal) : null;
  const neededOnDay = document.getElementById('item-needed-day').value.trim() || null;
  if (editId) {
    const item = trip.checklistItems.find(i => i.id === editId);
    if (item) Object.assign(item, { text, category, priority, quantity, neededOnDay });
  } else {
    trip.checklistItems.push({ id: genId(), tripId, dayId: null, text, category, priority, checked: false, quantity, neededOnDay });
  }
  saveTrip(trip); closeModal('modal-item'); renderPackingList();
  window.showToast?.(editId ? 'Item updated' : 'Item added');
});

// ── Destination Modal ────────────────────────────────────────────────────────

let selectedDestCountry = null;

function updateDestCountryInfo(country) {
  const info = document.getElementById('dest-country-info');
  if (!country) {
    info?.classList.add('hidden');
    selectedDestCountry = null;
    return;
  }
  info?.classList.remove('hidden');
  document.getElementById('dest-info-currency').textContent = `${country.currency} (${country.currencyCode})`;
  document.getElementById('dest-info-plugs').textContent = country.plugTypes.join(', ') || '—';
  document.getElementById('dest-info-voltage').textContent = country.voltage || '—';
  const warn = document.getElementById('dest-voltage-warn');
  if (warn) warn.classList.toggle('hidden', parseInt(country.voltage) < 220);
}

function openDestinationModal(editId = null) {
  document.getElementById('form-destination').reset();
  document.getElementById('dest-edit-id').value = '';
  document.getElementById('modal-dest-title').textContent = editId ? 'Edit Destination' : 'Add Destination';
  document.getElementById('dest-country-info').classList.add('hidden');
  selectedDestCountry = null;

  if (editId) {
    const d = (trip.destinations ?? []).find(d => d.id === editId);
    if (d) {
      document.getElementById('dest-edit-id').value = d.id;
      document.getElementById('dest-city').value = d.city ?? '';
      document.getElementById('dest-region').value = d.region ?? '';
      document.getElementById('dest-country').value = d.country ?? '';
      document.getElementById('dest-arrival').value = d.arrivalDate ?? '';
      document.getElementById('dest-departure').value = d.departureDate ?? '';
      document.getElementById('dest-currency-notes').value = d.currencyNotes ?? '';
      document.getElementById('dest-atm-notes').value = d.atmNotes ?? '';
      document.getElementById('dest-card-notes').value = d.cardNotes ?? '';

      // Set selected country for autocomplete
      if (d.country && d.countryCode) {
        selectedDestCountry = { name: d.country, code: d.countryCode };
        updateDestCountryInfo(getCountry(d.countryCode));
      }
    }
  }

  // Default arrival/departure to trip dates or last destination's departure
  if (!editId) {
    const dests = trip.destinations ?? [];
    if (dests.length > 0) {
      // Sort destinations by arrival date to find the chronologically last one
      const sortedDests = dests
        .filter(d => d.arrivalDate) // Only destinations with arrival dates
        .sort((a, b) => new Date(a.arrivalDate) - new Date(b.arrivalDate));

      if (sortedDests.length > 0) {
        // Set arrival to last destination's departure date
        const lastDest = sortedDests[sortedDests.length - 1];
        document.getElementById('dest-arrival').value = lastDest.departureDate || trip.endDate || '';
      } else {
        // No destinations with dates, default to trip start
        document.getElementById('dest-arrival').value = trip.startDate || '';
      }
    } else {
      // No existing destinations, default to trip start
      document.getElementById('dest-arrival').value = trip.startDate || '';
    }
    // Always default departure to trip end date
    document.getElementById('dest-departure').value = trip.endDate || '';
  }

  // Initialize country autocomplete
  initCountryAutocomplete('dest-country', 'dest-dropdown', (country) => {
    selectedDestCountry = country;
    updateDestCountryInfo(country);
  });

  openModal('modal-destination');
  setTimeout(() => document.getElementById('dest-country').focus(), 50);
}

document.getElementById('form-destination').addEventListener('submit', e => {
  e.preventDefault();
  const editId = document.getElementById('dest-edit-id').value;
  const countryInput = document.getElementById('dest-country').value.trim();

  if (!countryInput) {
    window.showToast?.('Please select a country');
    return;
  }

  const city = document.getElementById('dest-city').value.trim();
  const region = document.getElementById('dest-region').value.trim();

  // Use selected country from autocomplete or create basic entry
  const country = selectedDestCountry || null;
  const dest = {
    id: editId || genId(),
    city: city || '',
    region: region || '',
    country: country ? country.name : countryInput,
    countryCode: country ? country.code : '',
    arrivalDate: document.getElementById('dest-arrival').value || '',
    departureDate: document.getElementById('dest-departure').value || '',
    currency: country ? country.currency : '',
    currencyCode: country ? country.currencyCode : '',
    plugTypes: country ? (country.plugTypes || []) : [],
    voltage: country ? (country.voltage || '') : '',
    currencyNotes: document.getElementById('dest-currency-notes').value.trim(),
    atmNotes: document.getElementById('dest-atm-notes').value.trim(),
    cardNotes: document.getElementById('dest-card-notes').value.trim(),
  };

  if (!trip.destinations) trip.destinations = [];
  const idx = trip.destinations.findIndex(d => d.id === dest.id);
  if (idx >= 0) trip.destinations[idx] = dest; else trip.destinations.push(dest);

  // Apply auto-adjustment for dates
  autoAdjustDestinationDates(trip);
  recalcDatesFromDests();
  saveTrip(trip);
  closeModal('modal-destination');
  renderHeader(); renderItinerary(); renderInfo(); renderPackingList();
  window.showToast?.(editId ? 'Destination updated' : 'Destination added');

  // Offer international suggestions after a short delay
  const profile = getProfile();
  const homeCountryCode = profile.homeBase?.countryCode || 'US';
  if (dest.countryCode && dest.countryCode !== homeCountryCode) {
    setTimeout(() => openIntlSuggestModal(true), 500);
  }
});

// ── International Packing Suggestions ────────────────────────────────────────

function buildIntlSuggestions() {
  const profile = getProfile();
  const homeCountryCode = profile.homeBase?.countryCode || 'US';
  const dests = (trip.destinations ?? []).filter(d => d.countryCode && d.countryCode !== homeCountryCode);
  if (!dests.length) return [];
  const suggestions = [];
  // Power adapters — one per unique needed plug type
  const plugTypes = getNeededPlugTypes(dests);
  for (const plug of plugTypes) {
    const desc = PLUG_DESCRIPTIONS[plug] ?? `Type ${plug} adapter`;
    suggestions.push({ key: `adapter-${plug}`, text: `Power Adapter — ${desc}`, category: null, priority: 'essential' });
  }
  // 220V warning item
  if (needs220VWarning(dests)) {
    suggestions.push({ key: 'voltage-check', text: 'Check device voltage compatibility (220V destinations)', category: null, priority: 'dont-forget' });
  }
  // Standard international travel items
  suggestions.push({ key: 'passport', text: 'Passport', category: null, priority: 'essential' });
  suggestions.push({ key: 'intl-insurance', text: 'Travel insurance documents', category: null, priority: 'essential' });
  suggestions.push({ key: 'doc-copies', text: 'Copies of important documents (physical + digital)', category: null, priority: 'dont-forget' });
  suggestions.push({ key: 'bank-notify', text: 'Notify bank of travel dates', category: null, priority: 'dont-forget' });
  suggestions.push({ key: 'intl-data', text: 'International data plan / SIM card', category: null, priority: 'optional' });
  return suggestions;
}

function openIntlSuggestModal(onlyIfNew = false) {
  const suggestions = buildIntlSuggestions();
  if (!suggestions.length) return;
  const dismissed = trip.dismissedIntlSuggestions ?? [];
  const pending = suggestions.filter(s => !dismissed.includes(s.key));
  if (!pending.length) return;
  if (onlyIfNew) {
    // Check if any are already in the packing list
    const existingTexts = new Set((trip.checklistItems ?? []).map(i => i.text.toLowerCase()));
    const newItems = pending.filter(s => !existingTexts.has(s.text.toLowerCase()));
    if (!newItems.length) return;
  }

  document.getElementById('intl-suggest-list').innerHTML = pending.map((s, i) => `
    <label class="flex items-start gap-2.5 cursor-pointer p-2 rounded-lg hover:bg-gray-50">
      <input type="checkbox" class="intl-suggest-check mt-0.5 h-4 w-4 rounded text-indigo-600" data-key="${esc(s.key)}" data-idx="${i}" checked />
      <div>
        <p class="text-sm font-medium text-gray-800">${esc(s.text)}</p>
        ${s.priority ? `<p class="text-xs text-gray-400 capitalize">${s.priority.replace('-', ' ')}</p>` : ''}
      </div>
    </label>`).join('');

  openModal('modal-intl-suggest');

  document.getElementById('intl-suggest-skip').onclick = () => {
    // Dismiss all pending
    if (!trip.dismissedIntlSuggestions) trip.dismissedIntlSuggestions = [];
    pending.forEach(s => { if (!trip.dismissedIntlSuggestions.includes(s.key)) trip.dismissedIntlSuggestions.push(s.key); });
    saveTrip(trip); closeModal('modal-intl-suggest'); renderPackingList();
  };

  document.getElementById('intl-suggest-add').onclick = () => {
    const checked = document.querySelectorAll('.intl-suggest-check:checked');
    if (!trip.dismissedIntlSuggestions) trip.dismissedIntlSuggestions = [];
    let added = 0;
    checked.forEach(cb => {
      const s = pending[parseInt(cb.dataset.idx)];
      if (!s) return;
      // Only add if not already in list
      const exists = (trip.checklistItems ?? []).some(i => i.text.toLowerCase() === s.text.toLowerCase());
      if (!exists) {
        if (!trip.checklistItems) trip.checklistItems = [];
        trip.checklistItems.push({ id: genId(), tripId, dayId: null, text: s.text, category: s.category, priority: s.priority, checked: false, quantity: null });
        added++;
      }
      if (!trip.dismissedIntlSuggestions.includes(s.key)) trip.dismissedIntlSuggestions.push(s.key);
    });
    // Dismiss unchecked too
    document.querySelectorAll('.intl-suggest-check:not(:checked)').forEach(cb => {
      const key = cb.dataset.key;
      if (key && !trip.dismissedIntlSuggestions.includes(key)) trip.dismissedIntlSuggestions.push(key);
    });
    saveTrip(trip); closeModal('modal-intl-suggest'); renderPackingList();
    if (added > 0) window.showToast?.(`${added} item${added !== 1 ? 's' : ''} added to packing list`);
  };
}

// ── Laundry Plan Helper ───────────────────────────────────────────────────────

function applyLaundryToClothing() {
  const laundry = trip.laundryPlan ?? { enabled: false, everyXDays: 7 };
  // Clear manual overrides so recalculation uses laundry plan
  trip.clothingOverrides = {};
  const clothing = calcClothing(trip.nights, {}, profile.clothingDefaults ?? {}, laundry);
  (trip.checklistItems ?? []).forEach(item => {
    if (!item.isClothing) return;
    item.quantity = clothing[item.clothingType] ?? item.quantity;
  });
}

// ── Itinerary ────────────────────────────────────────────────────────────────

function renderItinerary() {
  const panel = document.getElementById('tab-itinerary');
  const events = trip.itineraryEvents ?? [];
  const byDay = {};
  trip.days.forEach(d => (byDay[d.id] = []));
  events.forEach(ev => { if (byDay[ev.dayId]) byDay[ev.dayId].push(ev); });
  trip.days.forEach(d => byDay[d.id].sort((a, b) => (a.time ?? '').localeCompare(b.time ?? '')));

  const dests = trip.destinations ?? [];
  const hasDests = dests.length > 0;

  // Build sections: group days by destination
  let sections;
  if (hasDests) {
    const destSections = dests.map(dest => ({
      dest,
      days: trip.days.filter(d => d.date >= dest.arrivalDate && d.date <= dest.departureDate),
    })).filter(s => s.days.length > 0);
    const assignedIds = new Set(destSections.flatMap(s => s.days.map(d => d.id)));
    const unassigned = trip.days.filter(d => !assignedIds.has(d.id));
    sections = [...destSections, ...(unassigned.length ? [{ dest: null, days: unassigned }] : [])];
  } else {
    sections = [{ dest: null, days: trip.days }];
  }

  function renderDestHeader(dest) {
    if (!dest) return hasDests ? `<div class="px-4 py-2 bg-gray-50 border-b border-gray-100 border-t mt-2"><span class="text-sm font-semibold text-gray-500">Other Days</span></div>` : '';
    const dateRange = (dest.arrivalDate && dest.departureDate) ? ` · ${formatDate(dest.arrivalDate)} – ${formatDate(dest.departureDate)}` : '';
    return `<div class="px-4 py-2.5 bg-indigo-50 border-b border-indigo-100 ${hasDests ? 'border-t border-indigo-100' : ''}">
      <span class="text-sm font-bold text-indigo-900">${dest.city ? esc(dest.city) + (dest.country ? ', ' + esc(dest.country) : '') : esc(dest.country)}</span>
      <span class="text-xs text-indigo-500 ml-1.5">${esc(dateRange)}</span>
    </div>`;
  }

  panel.innerHTML = `
    ${!readonly ? `<div class="px-4 py-3 border-b border-gray-100 flex justify-end">
      <button id="btn-add-event-top" class="btn-primary text-xs py-1.5 px-3">+ Add Event</button>
    </div>` : ''}
    ${sections.map(({ dest, days }) => renderDestHeader(dest) + days.map(day => {
      const dayEvents = byDay[day.id] ?? [];
      return `<div class="mb-1">
        <div class="flex items-center justify-between px-4 py-2 bg-gray-50 border-b border-gray-100">
          <div><span class="text-sm font-semibold text-gray-800">${esc(day.label)}</span>
            <span class="text-xs text-gray-400 ml-1.5">${formatDate(day.date)}</span></div>
          ${!readonly ? `<button class="add-event-day text-xs text-indigo-600 hover:text-indigo-800 font-medium" data-day-id="${esc(day.id)}">+ Event</button>` : ''}
        </div>
        <div class="divide-y divide-gray-50">
          ${dayEvents.map(ev => renderEventRow(ev)).join('')}
          ${dayEvents.length === 0 ? `<div class="px-4 py-3 text-xs text-gray-400 italic">No events</div>` : ''}
        </div>
      </div>`;
    }).join('')).join('')}`;

  panel.querySelector('#btn-add-event-top')?.addEventListener('click', () => openEventModal());
  panel.querySelectorAll('.add-event-day').forEach(btn => btn.addEventListener('click', () => openEventModal(btn.dataset.dayId)));
  panel.querySelectorAll('[data-edit-event]').forEach(btn => btn.addEventListener('click', () => openEventModal(null, btn.dataset.editEvent)));
  panel.querySelectorAll('[data-del-event]').forEach(btn => btn.addEventListener('click', () => deleteEvent(btn.dataset.delEvent)));
}

function renderEventRow(ev) {
  const editDel = !readonly ? `
    <div class="flex gap-1 ml-2 opacity-0 group-hover:opacity-100 transition-opacity">
      <button data-edit-event="${esc(ev.id)}" class="btn-ghost p-1 text-xs" title="Edit">✏️</button>
      <button data-del-event="${esc(ev.id)}" class="btn-ghost p-1 text-xs text-red-400 hover:text-red-600" title="Delete">×</button>
    </div>` : '';
  return `<div class="group flex gap-3 px-4 py-3 hover:bg-gray-50 transition-colors">
    <div class="flex-shrink-0 w-14 text-right"><span class="text-xs font-mono text-indigo-600 font-medium">${ev.time ? esc(ev.time) : '—'}</span></div>
    <div class="flex-1 min-w-0">
      <p class="text-sm font-medium text-gray-900">${esc(ev.title)}</p>
      ${ev.notes ? `<p class="text-xs text-gray-500 mt-0.5">${esc(ev.notes)}</p>` : ''}
    </div>
    ${editDel}
  </div>`;
}

function deleteEvent(eventId) {
  trip.itineraryEvents = trip.itineraryEvents.filter(e => e.id !== eventId);
  saveTrip(trip); renderItinerary(); window.showToast?.('Event removed');
}

// ── Event Modal ──────────────────────────────────────────────────────────────

function openEventModal(preselectedDayId = null, editEventId = null) {
  document.getElementById('form-event').reset();
  document.getElementById('event-edit-id').value = '';
  document.getElementById('modal-event-title').textContent = editEventId ? 'Edit Event' : 'Add Event';
  document.getElementById('event-day').innerHTML = trip.days.map(d =>
    `<option value="${esc(d.id)}" ${d.id === preselectedDayId ? 'selected' : ''}>${esc(d.label)}</option>`).join('');
  if (editEventId) {
    const ev = trip.itineraryEvents.find(e => e.id === editEventId);
    if (ev) {
      document.getElementById('event-edit-id').value = ev.id;
      document.getElementById('event-title').value = ev.title;
      document.getElementById('event-day').value = ev.dayId;
      document.getElementById('event-time').value = ev.time ?? '';
      document.getElementById('event-notes').value = ev.notes ?? '';
    }
  }
  openModal('modal-event');
  setTimeout(() => document.getElementById('event-title').focus(), 50);
}

document.getElementById('form-event').addEventListener('submit', e => {
  e.preventDefault();
  const editId = document.getElementById('event-edit-id').value;
  const title = document.getElementById('event-title').value.trim();
  const dayId = document.getElementById('event-day').value;
  const time = document.getElementById('event-time').value;
  const notes = document.getElementById('event-notes').value.trim();
  if (editId) {
    const ev = trip.itineraryEvents.find(e => e.id === editId);
    if (ev) Object.assign(ev, { title, dayId, time, notes });
  } else {
    if (!trip.itineraryEvents) trip.itineraryEvents = [];
    trip.itineraryEvents.push({ id: genId(), tripId, dayId, time, title, notes });
  }
  saveTrip(trip); closeModal('modal-event'); renderItinerary();
  window.showToast?.(editId ? 'Event updated' : 'Event added');
});

// ── Info Tab ──────────────────────────────────────────────────────────────────

function infoRow(label, value, placeholder = '—') {
  const v = value ? esc(value) : `<span class="text-gray-400 italic text-xs">${placeholder}</span>`;
  return `<div class="flex justify-between items-baseline gap-3 py-1.5 border-b border-gray-50 last:border-0">
    <span class="text-gray-500 text-sm flex-shrink-0">${label}</span>
    <span class="font-medium text-sm text-right break-all">${v}</span>
  </div>`;
}

function renderInfo() {
  const panel = document.getElementById('tab-info');
  panel.innerHTML =
    renderInfoBasics() +
    renderInfoDestinations() +
    renderInfoFlight() +
    renderInfoHotel() +
    renderInfoTransport() +
    renderInfoDocuments() +
    renderInfoMembers() +
    renderInfoActions();
  attachInfoListeners();
}

