  // Documents section — insurance toggle
  document.getElementById('doc-insurance-check')?.addEventListener('change', e => {
    document.getElementById('doc-insurance-fields')?.classList.toggle('hidden', !e.target.checked);
  });

  // Visa dismiss checkboxes
  document.querySelectorAll('.visa-dismiss-check').forEach(cb => {
    cb.addEventListener('change', () => {
      if (!trip.travelDocuments.dismissedVisaReminders) trip.travelDocuments.dismissedVisaReminders = [];
      if (cb.checked) {
        if (!trip.travelDocuments.dismissedVisaReminders.includes(cb.dataset.countryCode))
          trip.travelDocuments.dismissedVisaReminders.push(cb.dataset.countryCode);
      } else {
        trip.travelDocuments.dismissedVisaReminders = trip.travelDocuments.dismissedVisaReminders.filter(c => c !== cb.dataset.countryCode);
      }
      saveTrip(trip);
    });
  });

  // Custom reminders
  document.querySelectorAll('.custom-reminder-check').forEach(cb => {
    cb.addEventListener('change', () => {
      const r = (trip.travelDocuments?.customReminders ?? []).find(r => r.id === cb.dataset.reminderId);
      if (r) { r.done = cb.checked; saveTrip(trip); renderInfo(); }
    });
  });
  document.querySelectorAll('.del-reminder').forEach(btn => {
    btn.addEventListener('click', () => {
      if (trip.travelDocuments?.customReminders)
        trip.travelDocuments.customReminders = trip.travelDocuments.customReminders.filter(r => r.id !== btn.dataset.reminderId);
      saveTrip(trip); renderInfo();
    });
  });
  document.getElementById('form-custom-reminder')?.addEventListener('submit', e => {
    e.preventDefault();
    const text = document.getElementById('custom-reminder-input').value.trim();
    if (!text) return;
    if (!trip.travelDocuments.customReminders) trip.travelDocuments.customReminders = [];
    trip.travelDocuments.customReminders.push({ id: genId(), text, done: false });
    saveTrip(trip); renderInfo();
  });

  document.getElementById('btn-add-member')?.addEventListener('click', openMemberModal);
  document.querySelectorAll('.del-member').forEach(btn => {
    btn.addEventListener('click', () => {
      const name = getMembers().find(m => m.id === btn.dataset.memberId)?.name ?? '';
      confirmAction('👤', 'Remove member?', `Remove "${name}" from this trip? This won't delete their expenses.`,
        'Remove', 'btn-danger',
        () => { trip.members = (trip.members ?? []).filter(m => m.id !== btn.dataset.memberId); saveTrip(trip); renderInfo(); renderExpenses(); });
    });
  });

  document.getElementById('info-export')?.addEventListener('click', () => exportTrip(trip));
  document.getElementById('info-duplicate')?.addEventListener('click', () => {
    confirmAction('📋', 'Duplicate this trip?', 'Creates a copy with all items unchecked.', 'Duplicate', 'btn-primary',
      () => { const copy = duplicateTrip(tripId); window.showToast?.(`"${copy.name}" created`); setTimeout(() => { location.href = `${BASE}trip/?id=${copy.id}`; }, 700); });
  });
  document.getElementById('info-archive')?.addEventListener('click', () => {
