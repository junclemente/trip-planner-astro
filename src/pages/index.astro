---
import Layout from '../layouts/Layout.astro';
import NewTripModal from '../components/NewTripModal.astro';
---
<Layout title="Welcome" page="welcome" showNav={false}>

  <main class="min-h-screen flex flex-col items-center justify-center px-6 py-12 bg-gradient-to-b from-indigo-50 via-white to-white">

    <!-- Logo + name -->
    <div class="flex flex-col items-center mb-8">
      <div class="w-20 h-20 rounded-2xl bg-indigo-600 flex items-center justify-center shadow-lg mb-4">
        <svg class="w-11 h-11 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/>
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
          <circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 17v1.5M17 17v1.5"/>
        </svg>
      </div>
      <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Trip Planner</h1>
      <p class="text-gray-500 mt-1 text-base">Pack smart. Travel light.</p>
    </div>

    <!-- How it works -->
    <div class="w-full max-w-sm mb-8">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest text-center mb-4">How it works</h2>
      <div class="space-y-3">
        <div class="flex items-start gap-4 bg-white rounded-xl px-4 py-3 shadow-sm border border-gray-100">
          <div class="w-9 h-9 rounded-full bg-indigo-100 flex items-center justify-center flex-shrink-0 mt-0.5">
            <span class="text-lg">✈️</span>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-800">1. Create a trip</p>
            <p class="text-xs text-gray-500 mt-0.5">Pick a template — clothing quantities are calculated for you automatically.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-white rounded-xl px-4 py-3 shadow-sm border border-gray-100">
          <div class="w-9 h-9 rounded-full bg-indigo-100 flex items-center justify-center flex-shrink-0 mt-0.5">
            <span class="text-lg">📋</span>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-800">2. Pack your checklist</p>
            <p class="text-xs text-gray-500 mt-0.5">Essentials, clothing, and your personal items — all organized by day.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-white rounded-xl px-4 py-3 shadow-sm border border-gray-100">
          <div class="w-9 h-9 rounded-full bg-indigo-100 flex items-center justify-center flex-shrink-0 mt-0.5">
            <span class="text-lg">🌍</span>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-800">3. Travel!</p>
            <p class="text-xs text-gray-500 mt-0.5">Follow your itinerary and check off items as you pack. Have a great trip.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="w-full max-w-sm space-y-3">
      <button id="btn-create-trip"
              class="btn-primary w-full py-3 text-base rounded-xl shadow-md shadow-indigo-200">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        Create New Trip
      </button>

      <a id="btn-view-trips" href="#"
         class="btn-secondary w-full py-3 text-base rounded-xl flex items-center justify-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        View My Trips
      </a>

      <div class="text-center pt-1">
        <button id="btn-import-welcome"
                class="text-sm text-gray-400 hover:text-indigo-600 transition-colors underline underline-offset-2">
          Import trip from JSON
        </button>
        <input id="import-file-welcome" type="file" accept=".json" class="hidden" />
      </div>
    </div>

  </main>

  <!-- New Trip Modal Component -->
  <NewTripModal />

</Layout>

<script>
import { importTripFromJSON } from '../scripts/store.js';

const BASE = import.meta.env.BASE_URL;

// Set "View My Trips" href dynamically (uses BASE)
document.getElementById('btn-view-trips').href = `${BASE}trips/`;

// ── New trip modal event handlers ────────────────────────────────────────────

document.getElementById('btn-create-trip').addEventListener('click', () => {
  window.dispatchEvent(new CustomEvent('open-new-trip-modal'));
});

// Listen for trip-created event from modal
window.addEventListener('trip-created', (e) => {
  window.location.href = `${BASE}trip/?id=${(e as CustomEvent).detail.tripId}`;
});

// ── Import ────────────────────────────────────────────────────────────────────

document.getElementById('btn-import-welcome').addEventListener('click', () => {
  document.getElementById('import-file-welcome').click();
});

document.getElementById('import-file-welcome').addEventListener('change', e => {
  const file = e.target.files?.[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    try {
      const trip = importTripFromJSON(ev.target.result);
      window.showToast?.(`"${trip.name}" imported!`);
      setTimeout(() => { window.location.href = `${BASE}trip/?id=${trip.id}`; }, 600);
    } catch (err) {
      window.showToast?.(`Import failed: ${err.message}`);
    }
    e.target.value = '';
  };
  reader.readAsText(file);
});
</script>
