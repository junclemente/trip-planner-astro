---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="My Trips" page="trips">

  <!-- Header -->
  <header class="sticky top-0 z-30 bg-white border-b border-gray-100 shadow-sm">
    <div class="flex items-center justify-between px-4 py-3 max-w-lg mx-auto">
      <div class="flex items-center gap-2">
        <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <h1 class="text-lg font-bold text-gray-900">My Trips</h1>
      </div>
      <button id="btn-new-trip" class="btn-primary text-sm py-1.5 px-3">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        New Trip
      </button>
    </div>
  </header>

  <!-- Trip list -->
  <main class="max-w-lg mx-auto px-4 py-4">
    <div id="trips-container"></div>
  </main>

  <!-- ── New Trip Modal ── -->
  <div id="modal-new-trip" class="modal-overlay hidden">
    <div class="modal-box">
      <div class="flex items-center justify-between p-4 border-b">
        <h2 class="text-lg font-bold">New Trip</h2>
        <button id="close-new-trip" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
      </div>
      <form id="form-new-trip" class="p-4 space-y-4" style="overflow: visible;">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Trip Name *</label>
          <input id="nt-name" type="text" class="input" placeholder="e.g. Weekend in NYC" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Country *</label>
          <div class="relative overflow-visible">
            <input id="nt-country" type="text" class="input" placeholder="Start typing country name..." required
                   autocomplete="off" />
            <ul id="country-dropdown" class="absolute z-[9999] w-full bg-white border border-gray-200 rounded-lg shadow-lg hidden max-h-48 overflow-y-auto top-full mt-1" style="z-index: 9999;">
              <!-- Country options populated by JavaScript -->
            </ul>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Departing From</label>
          <input id="nt-depart" type="text" class="input" placeholder="e.g. San Diego, CA" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Start Date *</label>
          <input id="nt-start" type="date" class="input" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Template</label>
          <div class="grid grid-cols-2 gap-2">
            <label class="flex items-center gap-2 border rounded-lg p-2.5 cursor-pointer hover:border-indigo-400 transition-colors">
              <input type="radio" name="template" value="overnight" class="text-indigo-600" />
              <div><div class="text-sm font-medium">Overnight</div><div class="text-xs text-gray-500">1 night</div></div>
            </label>
            <label class="flex items-center gap-2 border rounded-lg p-2.5 cursor-pointer hover:border-indigo-400 transition-colors">
              <input type="radio" name="template" value="weekend" class="text-indigo-600" />
              <div><div class="text-sm font-medium">Weekend</div><div class="text-xs text-gray-500">2 nights</div></div>
            </label>
            <label class="flex items-center gap-2 border rounded-lg p-2.5 cursor-pointer hover:border-indigo-400 transition-colors">
              <input type="radio" name="template" value="short" class="text-indigo-600" />
              <div><div class="text-sm font-medium">Short Trip</div><div class="text-xs text-gray-500">3 nights</div></div>
            </label>
            <label class="flex items-center gap-2 border rounded-lg p-2.5 cursor-pointer hover:border-indigo-400 transition-colors">
              <input type="radio" name="template" value="week" class="text-indigo-600" />
              <div><div class="text-sm font-medium">Week Trip</div><div class="text-xs text-gray-500">7 nights</div></div>
            </label>
            <label class="col-span-2 flex items-center gap-2 border rounded-lg p-2.5 cursor-pointer hover:border-indigo-400 transition-colors">
              <input type="radio" name="template" value="custom" class="text-indigo-600" />
              <div><div class="text-sm font-medium">Custom</div><div class="text-xs text-gray-500">Set nights manually</div></div>
            </label>
          </div>
        </div>
        <div id="custom-nights-row" class="hidden">
          <label class="block text-sm font-medium text-gray-700 mb-1">Number of Nights *</label>
          <input id="nt-nights" name="nt-nights" type="number" min="1" max="365" class="input" placeholder="e.g. 5" required />
        </div>
        <div id="nt-end-display" class="text-sm text-gray-500 hidden">
          Returns: <span id="nt-end-date-text" class="font-medium text-gray-800"></span>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" id="cancel-new-trip" class="btn-secondary flex-1">Cancel</button>
          <button type="submit" class="btn-primary flex-1">Create Trip</button>
        </div>
      </form>
    </div>
  </div>

</Layout>

<script>
import { getTrips, saveTrip, getProfile, genId } from '../../scripts/store.js';
import {
  TEMPLATES, buildDays, buildInitialChecklist, calcEndDate, formatDateRange,
} from '../../scripts/templates.js';
import { COUNTRIES } from '../../data/countries.js';

const BASE = import.meta.env.BASE_URL;

// ── Render ────────────────────────────────────────────────────────────────────

function esc(s) {
  const d = document.createElement('div');
  d.textContent = String(s ?? '');
  return d.innerHTML;
}

function progressBar(checked, total) {
  const pct = total === 0 ? 0 : Math.round((checked / total) * 100);
  return `
    <div class="mt-2">
      <div class="flex justify-between text-xs text-gray-500 mb-1">
        <span>${checked}/${total} items packed</span><span>${pct}%</span>
      </div>
      <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
        <div class="h-full bg-indigo-500 rounded-full transition-all" style="width:${pct}%"></div>
      </div>
    </div>`;
}

function renderTrips() {
  const trips = getTrips().filter(t => t.status === 'active');
  const container = document.getElementById('trips-container');

  if (trips.length === 0) {
    container.innerHTML = `
      <div class="flex flex-col items-center justify-center py-20 text-center">
        <div class="text-5xl mb-4">✈️</div>
        <h2 class="text-xl font-bold text-gray-800 mb-2">No active trips</h2>
        <p class="text-gray-500 text-sm mb-6">Ready for your next adventure?</p>
        <button id="empty-new-trip" class="btn-primary">+ New Trip</button>
      </div>`;
    document.getElementById('empty-new-trip')?.addEventListener('click', openNewTripModal);
    return;
  }

  container.innerHTML = trips.map(trip => {
    const total = trip.checklistItems?.length ?? 0;
    const checked = trip.checklistItems?.filter(i => i.checked).length ?? 0;
    const tmpl = TEMPLATES[trip.template]?.label ?? trip.template;
    return `
      <div class="card p-4 mb-3 cursor-pointer hover:shadow-md transition-shadow"
           data-trip-id="${trip.id}">
        <div class="flex items-start justify-between gap-2">
          <div class="flex-1 min-w-0">
            <h3 class="font-bold text-gray-900 truncate">${esc(trip.name)}</h3>
            <p class="text-sm text-gray-500 flex items-center gap-1 mt-0.5">
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              ${esc(trip.destination)}
            </p>
          </div>
          <span class="text-xs bg-indigo-50 text-indigo-700 px-2 py-1 rounded-full font-medium flex-shrink-0">
            ${esc(tmpl)}
          </span>
        </div>
        <p class="text-xs text-gray-500 mt-2">
          📅 ${formatDateRange(trip.startDate, trip.endDate)}
          · ${trip.nights} night${trip.nights !== 1 ? 's' : ''}
          ${trip.departFrom ? `· from ${esc(trip.departFrom)}` : ''}
        </p>
        ${progressBar(checked, total)}
      </div>`;
  }).join('');

  container.querySelectorAll('[data-trip-id]').forEach(el => {
    el.addEventListener('click', () => {
      window.location.href = `${BASE}trip/?id=${el.dataset.tripId}`;
    });
  });
}

// ── New trip modal ────────────────────────────────────────────────────────────

function openNewTripModal() {
  document.getElementById('modal-new-trip').classList.remove('hidden');
  // Ensure a template is always selected by default
  const radio = document.querySelector('input[name="template"][value="weekend"]');
  if (radio) {
    radio.checked = true;
    updateEndDate();
  }

  // Initialize nights input state (disabled since weekend template is selected)
  const nightsInput = document.getElementById('nt-nights');
  nightsInput.disabled = true;
  nightsInput.required = false;

  // Auto-populate "Departing From" with home base
  const profile = getProfile();
  const departInput = document.getElementById('nt-depart');
  if (!departInput.value.trim() && profile.homeBase?.country) {
    departInput.value = profile.homeBase.country;
  }

  setTimeout(() => document.getElementById('nt-name').focus(), 50);
}

function closeNewTripModal() {
  document.getElementById('modal-new-trip').classList.add('hidden');
  document.getElementById('form-new-trip').reset();
  document.getElementById('custom-nights-row').classList.add('hidden');
  document.getElementById('nt-end-display').classList.add('hidden');

  // Reset nights input state
  const nightsInput = document.getElementById('nt-nights');
  nightsInput.disabled = true;
  nightsInput.required = false;

  hideDropdown();
  selectedCountry = null;
}

function updateEndDate() {
  const start = document.getElementById('nt-start').value;
  const template = document.querySelector('input[name="template"]:checked')?.value;
  const customNights = parseInt(document.getElementById('nt-nights').value);
  let nights = null;
  if (template && template !== 'custom') nights = TEMPLATES[template].nights;
  else if (template === 'custom' && customNights > 0) nights = customNights;
  if (start && nights !== null) {
    const end = calcEndDate(start, nights);
    const txt = new Date(`${end}T12:00:00`).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
    document.getElementById('nt-end-date-text').textContent = txt;
    document.getElementById('nt-end-display').classList.remove('hidden');
  } else {
    document.getElementById('nt-end-display').classList.add('hidden');
  }
}

document.getElementById('btn-new-trip').addEventListener('click', openNewTripModal);
document.getElementById('close-new-trip').addEventListener('click', closeNewTripModal);
document.getElementById('cancel-new-trip').addEventListener('click', closeNewTripModal);
document.getElementById('modal-new-trip').addEventListener('click', e => {
  if (e.target === e.currentTarget) closeNewTripModal();
});
document.querySelectorAll('input[name="template"]').forEach(r => {
  r.addEventListener('change', () => {
    const isCustom = r.value === 'custom';
    const nightsInput = document.getElementById('nt-nights');
    const nightsRow = document.getElementById('custom-nights-row');

    // Toggle visibility
    nightsRow.classList.toggle('hidden', !isCustom);

    // Manage validation attributes
    if (isCustom) {
      nightsInput.disabled = false;
      nightsInput.required = true;
    } else {
      nightsInput.disabled = true;
      nightsInput.required = false;
    }

    updateEndDate();
  });
});
document.getElementById('nt-start').addEventListener('change', updateEndDate);
document.getElementById('nt-nights').addEventListener('input', updateEndDate);

// ── Country autocomplete event listeners ─────────────────────────────────────
let currentCountries = [];

document.getElementById('nt-country').addEventListener('input', e => {
  const query = e.target.value;
  selectedCountry = null;
  focusedIndex = -1;

  if (query.trim()) {
    currentCountries = filterCountries(query);
    renderCountryDropdown(currentCountries);
  } else {
    hideDropdown();
  }
});

document.getElementById('nt-country').addEventListener('keydown', e => {
  if (currentCountries.length === 0) return;

  switch (e.key) {
    case 'ArrowDown':
      e.preventDefault();
      focusedIndex = Math.min(focusedIndex + 1, currentCountries.length - 1);
      renderCountryDropdown(currentCountries);
      break;

    case 'ArrowUp':
      e.preventDefault();
      focusedIndex = Math.max(focusedIndex - 1, -1);
      renderCountryDropdown(currentCountries);
      break;

    case 'Enter':
      e.preventDefault();
      if (focusedIndex >= 0 && focusedIndex < currentCountries.length) {
        selectCountry(currentCountries[focusedIndex]);
      }
      break;

    case 'Escape':
      hideDropdown();
      break;
  }
});

document.getElementById('nt-country').addEventListener('blur', () => {
  // Delay hiding to allow click events on dropdown items
  setTimeout(() => hideDropdown(), 150);
});

// Close dropdown when clicking outside
document.addEventListener('click', e => {
  if (!e.target.closest('#nt-country') && !e.target.closest('#country-dropdown')) {
    hideDropdown();
  }
});

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeNewTripModal(); });

// ── Country autocomplete ─────────────────────────────────────────────────────

let selectedCountry = null;
let focusedIndex = -1;

function filterCountries(query) {
  if (!query.trim()) return [];

  const normalized = query.toLowerCase().trim();
  const matches = COUNTRIES.filter(country =>
    country.name.toLowerCase().includes(normalized)
  );

  // Sort exact matches first, then by length
  return matches
    .sort((a, b) => {
      const aExact = a.name.toLowerCase().startsWith(normalized);
      const bExact = b.name.toLowerCase().startsWith(normalized);
      if (aExact && !bExact) return -1;
      if (bExact && !aExact) return 1;
      return a.name.length - b.name.length;
    })
    .slice(0, 8);
}

function renderCountryDropdown(countries) {
  const dropdown = document.getElementById('country-dropdown');

  if (countries.length === 0) {
    dropdown.classList.add('hidden');
    return;
  }

  dropdown.innerHTML = countries.map((country, index) => {
    // Get flag emoji from country code (simple approach)
    const flag = getCountryFlag(country.code);
    const isActive = index === focusedIndex;

    return `
      <li class="px-3 py-2 cursor-pointer hover:bg-gray-50 ${isActive ? 'bg-indigo-50' : ''}"
           data-country-index="${index}">
        <span class="text-lg">${flag}</span> ${esc(country.name)}
      </li>
    `;
  }).join('');

  dropdown.classList.remove('hidden');

  // Add click listeners
  dropdown.querySelectorAll('[data-country-index]').forEach(el => {
    el.addEventListener('click', () => {
      const index = parseInt(el.dataset.countryIndex);
      selectCountry(countries[index]);
    });
  });
}

function getCountryFlag(countryCode) {
  // Simple flag emoji conversion (works for most countries)
  if (!countryCode || countryCode.length !== 2) return '🌍';
  const codePoints = countryCode.toUpperCase().split('').map(char =>
    127397 + char.charCodeAt(0)
  );
  return String.fromCodePoint(...codePoints);
}

function selectCountry(country) {
  selectedCountry = country;
  document.getElementById('nt-country').value = country.name;
  document.getElementById('country-dropdown').classList.add('hidden');
  focusedIndex = -1;

  // Auto-fill trip name if empty
  const nameInput = document.getElementById('nt-name');
  if (!nameInput.value.trim()) {
    nameInput.value = `Trip to ${country.name}`;
  }
}

function hideDropdown() {
  document.getElementById('country-dropdown').classList.add('hidden');
  focusedIndex = -1;
}

function createDestinationFromCountry(country, startDate, endDate) {
  if (!country) return null;

  return {
    id: genId(),
    country: country.name,
    countryCode: country.code,
    city: '',
    region: '',
    arrivalDate: startDate,
    departureDate: endDate,
    currency: country.currency,
    currencyCode: country.currencyCode,
    currencyNotes: '',
    plugTypes: country.plugTypes || [],
    voltage: country.voltage || ''
  };
}

document.getElementById('form-new-trip').addEventListener('submit', e => {
  e.preventDefault();

  try {
    const name = document.getElementById('nt-name').value.trim();
    const departFrom = document.getElementById('nt-depart').value.trim();
    const startDate = document.getElementById('nt-start').value;
    const template = document.querySelector('input[name="template"]:checked')?.value;

    if (!name) {
      window.showToast?.('Please enter a trip name');
      return;
    }

    if (!startDate) {
      window.showToast?.('Please select a start date');
      return;
    }

    // Handle template validation - handle case where no template is selected
    let nights = null;
    if (template && template !== 'custom') {
      nights = TEMPLATES[template]?.nights;
    } else if (template === 'custom') {
      nights = parseInt(document.getElementById('nt-nights').value);
    } else {
      // If no template selected, default to weekend (2 nights)
      nights = 2;
    }

    if (!nights || nights < 1) {
      window.showToast?.('Please set number of nights');
      return;
    }

    const endDate = calcEndDate(startDate, nights);
    const profile = getProfile();
    const tripId = `trip-${Date.now().toString(36)}`;
    const days = buildDays(tripId, startDate, nights);
    const checklistItems = buildInitialChecklist(tripId, nights, profile?.personalEssentials || [], profile?.clothingDefaults || {});

    // Create destination from selected country (fault-tolerant)
    let destinations = [];
    let destinationDisplayName = '';

    const countryInput = document.getElementById('nt-country').value.trim();

    if (selectedCountry) {
      // User selected from dropdown
      try {
        const destinationObj = createDestinationFromCountry(selectedCountry, startDate, endDate);
        if (destinationObj) {
          destinations = [destinationObj];
          destinationDisplayName = selectedCountry.name;
        }
      } catch (error) {
        console.warn('Error creating destination from country, creating trip with empty destinations:', error);
        // Continue with empty destinations array
      }
    } else if (countryInput) {
      // User typed but didn't select from dropdown - create basic destination
      try {
        destinationDisplayName = countryInput;
        const basicDestination = {
          id: genId(),
          country: countryInput,
          countryCode: '',
          city: '',
          region: '',
          arrivalDate: startDate,
          departureDate: endDate,
          currency: '',
          currencyCode: '',
          currencyNotes: '',
          plugTypes: [],
          voltage: ''
        };
        destinations = [basicDestination];
      } catch (error) {
        console.warn('Error creating basic destination:', error);
        // Continue with empty destinations array
      }
    }

    const trip = {
      id: tripId,
      name,
      destination: destinationDisplayName, // Keep for backward compatibility
      departFrom,
      startDate,
      endDate,
      nights,
      template: template ?? 'custom',
      status: 'active',
      createdAt: new Date().toISOString(),
      archivedAt: null,
      clothingOverrides: null,
      days,
      checklistItems,
      itineraryEvents: [],
      destinations,
      origin: { city: departFrom ?? '', country: 'USA' },
      travelDocuments: {
        passport: { name: '', expiryDate: '' },
        insurance: { hasInsurance: false, provider: '', policyNumber: '', notes: '' },
        customReminders: [],
        dismissedVisaReminders: []
      },
      laundryPlan: { enabled: false, everyXDays: 7 },
      dismissedIntlSuggestions: [],
    };

    saveTrip(trip);
    closeNewTripModal();
    renderTrips();
    window.showToast?.(`"${name}" created!`);
    setTimeout(() => { window.location.href = `${BASE}trip/?id=${tripId}`; }, 600);

  } catch (error) {
    console.error('Error creating trip:', error);
    window.showToast?.('Error creating trip. Please try again.');
  }
});

// ── Init ──────────────────────────────────────────────────────────────────────
renderTrips();

// Debug: Verify dropdown element exists
document.addEventListener('DOMContentLoaded', () => {
  const dropdown = document.getElementById('country-dropdown');
  const input = document.getElementById('nt-country');
  if (!dropdown) {
    console.error('Country dropdown element not found!');
  } else {
    console.log('Country dropdown element found:', dropdown);
  }
  if (!input) {
    console.error('Country input element not found!');
  } else {
    console.log('Country input element found:', input);
  }
});
</script>
