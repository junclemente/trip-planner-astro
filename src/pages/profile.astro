---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Profile" page="profile">

  <header class="sticky top-0 z-30 bg-white border-b border-gray-100 shadow-sm">
    <div class="flex items-center gap-3 px-4 py-3 max-w-lg mx-auto">
      <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
      <h1 class="text-lg font-bold text-gray-900">Profile</h1>
    </div>
  </header>

  <main class="max-w-lg mx-auto px-4 py-4 space-y-4">

    <div class="card p-4">
      <div class="flex items-start justify-between mb-3">
        <div>
          <h2 class="font-semibold text-gray-900">Personal Essentials</h2>
          <p class="text-xs text-gray-500 mt-0.5">Auto-included in every new trip</p>
        </div>
        <button id="btn-add-essential" class="btn-primary text-sm py-1.5 px-3">+ Add</button>
      </div>

      <ul id="essentials-list" class="divide-y divide-gray-100"></ul>
      <p id="no-essentials" class="text-sm text-gray-400 italic py-2 hidden">
        No personal essentials yet. Add things like contact lenses, CPAP, mouth guard…
      </p>
    </div>

    <div class="card p-4 bg-indigo-50 border-indigo-100">
      <h3 class="font-semibold text-indigo-800 text-sm mb-1">Always-included defaults</h3>
      <p class="text-xs text-indigo-600 mb-2">These appear in every trip automatically:</p>
      <div class="flex flex-wrap gap-1.5">
        <span class="badge bg-gray-100 text-gray-700">Toothbrush</span>
        <span class="badge bg-gray-100 text-gray-700">Toothpaste</span>
        <span class="badge bg-gray-100 text-gray-700">Deodorant</span>
        <span class="badge bg-gray-100 text-gray-700">Chapstick</span>
        <span class="badge bg-gray-100 text-gray-700">Phone + Charger</span>
        <span class="badge bg-gray-100 text-gray-700">Wallet + ID</span>
      </div>
    </div>

  </main>

  <!-- Add/Edit Essential Modal -->
  <div id="modal-essential" class="modal-overlay hidden">
    <div class="modal-box max-w-sm">
      <div class="flex items-center justify-between p-4 border-b">
        <h2 id="modal-essential-title" class="text-lg font-bold">Add Essential</h2>
        <button id="close-essential" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
      </div>
      <form id="form-essential" class="p-4 space-y-4">
        <input type="hidden" id="essential-edit-id" />
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Item Name *</label>
          <input id="essential-text" type="text" class="input"
                 placeholder="e.g. Contact lenses, CPAP, Mouth guard" required />
        </div>
        <div class="flex gap-3">
          <button type="button" id="cancel-essential" class="btn-secondary flex-1">Cancel</button>
          <button type="submit" class="btn-primary flex-1">Save</button>
        </div>
      </form>
    </div>
  </div>

</Layout>

<script>
import { getProfile, saveProfile } from '../scripts/store.js';

function esc(s) {
  const d = document.createElement('div');
  d.textContent = String(s ?? '');
  return d.innerHTML;
}

function renderList() {
  const profile = getProfile();
  const list = document.getElementById('essentials-list');
  const empty = document.getElementById('no-essentials');

  if (!profile.personalEssentials.length) {
    list.innerHTML = '';
    empty.classList.remove('hidden');
    return;
  }
  empty.classList.add('hidden');

  list.innerHTML = profile.personalEssentials.map(item => `
    <li class="flex items-center gap-3 py-2.5 group">
      <span class="flex-1 text-sm text-gray-800">${esc(item.text)}</span>
      <button class="edit-essential opacity-0 group-hover:opacity-100 text-gray-300 hover:text-indigo-500 transition-all p-1 text-xs"
              data-id="${esc(item.id)}" title="Edit">✏️</button>
      <button class="del-essential opacity-0 group-hover:opacity-100 text-gray-300 hover:text-red-400 transition-all text-lg leading-none p-1"
              data-id="${esc(item.id)}" title="Remove">×</button>
    </li>`).join('');

  list.querySelectorAll('.del-essential').forEach(btn => {
    btn.addEventListener('click', () => {
      const profile = getProfile();
      profile.personalEssentials = profile.personalEssentials.filter(i => i.id !== btn.dataset.id);
      saveProfile(profile);
      renderList();
      window.showToast?.('Removed');
    });
  });

  list.querySelectorAll('.edit-essential').forEach(btn => {
    btn.addEventListener('click', () => openModal(btn.dataset.id));
  });
}

function openModal(editId = null) {
  const form = document.getElementById('form-essential');
  form.reset();
  document.getElementById('essential-edit-id').value = '';
  document.getElementById('modal-essential-title').textContent = editId ? 'Edit Essential' : 'Add Essential';

  if (editId) {
    const profile = getProfile();
    const item = profile.personalEssentials.find(i => i.id === editId);
    if (item) {
      document.getElementById('essential-edit-id').value = item.id;
      document.getElementById('essential-text').value = item.text;
    }
  }
  document.getElementById('modal-essential').classList.remove('hidden');
  setTimeout(() => document.getElementById('essential-text').focus(), 50);
}

function closeModal() {
  document.getElementById('modal-essential').classList.add('hidden');
}

document.getElementById('btn-add-essential').addEventListener('click', () => openModal());
document.getElementById('close-essential').addEventListener('click', closeModal);
document.getElementById('cancel-essential').addEventListener('click', closeModal);
document.getElementById('modal-essential').addEventListener('click', e => {
  if (e.target === e.currentTarget) closeModal();
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

document.getElementById('form-essential').addEventListener('submit', e => {
  e.preventDefault();
  const text = document.getElementById('essential-text').value.trim();
  const editId = document.getElementById('essential-edit-id').value;
  const profile = getProfile();

  if (editId) {
    const item = profile.personalEssentials.find(i => i.id === editId);
    if (item) item.text = text;
  } else {
    const id = `pe-${Date.now().toString(36)}`;
    profile.personalEssentials.push({ id, text });
  }
  saveProfile(profile);
  closeModal();
  renderList();
  window.showToast?.(editId ? 'Updated' : 'Added to personal essentials');
});

renderList();
</script>
